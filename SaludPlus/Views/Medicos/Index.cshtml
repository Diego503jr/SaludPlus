
@{
    ViewBag.Title = "Gestión de Médicos";
}

<link href="@Url.Content("~/Content/styles/Admin.css")" rel="stylesheet" />

@* Estructura de tabla *@
<div class="container-fluid mt-4 px-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white border-bottom py-3 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <h5 id="tituloVista" class="fw-bold mb-0 text-dark text-center text-md-start">Directorio Médico</h5>

            <div class="d-flex gap-2 justify-content-center">
                <button id="btnAgregar" class="btn btn-primary btn-sm px-3 shadow-sm" onclick="abrirModal(null)">
                    <i class="bi bi-plus-lg me-1"></i> Agregar
                </button>
                <button class="btn btn-outline-secondary btn-sm px-3" onclick="cargarDatosHistorial()">
                    <i class="fas fa-history me-1"></i> Historial
                </button>
                <button class="btn btn-light btn-sm px-2 border shadow-sm" onclick="cargarDatos()" title="Refrescar">
                    <i class="fas fa-arrow-left text-primary"></i>
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-nowrap mb-0" id="tablaMedicos">
                <thead class="table-light">
                    <tr>
                        <th class="text-muted">Médico</th>
                        <th class="ps-4 text-muted" style="width: 120px;">Horario</th>
                        <th class="text-muted">Especialidad</th>
                        <th class="text-muted">Consultorio</th>
                        <th class="text-muted">Telefono</th>
                        <th class="text-muted">Estado</th>
                        <th class="text-muted pe-4 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modal para registro/modificación de Médicos *@
<div class="modal fade" id="modalMedico" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="modal-header bg-dark text-white border-0 py-3 px-4">
                <h6 class="modal-title d-flex align-items-center fw-bold">
                    <i class="bi bi-person-badge-fill me-2 fs-5"></i>
                    GESTIÓN DE MÉDICO
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="bg-primary bg-opacity-10 py-3 px-4 border-bottom border-primary border-opacity-25">
                <div class="row align-items-center">
                    <div class="col-md-1 text-center d-none d-md-block">
                        <i class="bi bi-person-circle fs-2 text-primary"></i>
                    </div>
                    <div class="col-md-11">
                        <label class="small fw-bold text-primary text-uppercase mb-1" style="font-size: 0.65rem;">Usuario</label>
                        <select id="cboUsuario" class="form-select border-primary border-opacity-25 shadow-sm">
                            <option value="">-- Seleccione el nombre del médico --</option>
                        </select>
                    </div>
                </div>
            </div>

            <div class="modal-body p-0">
                @Html.Hidden("txtIdMedico", "0")

                <div class="container-fluid py-4 px-4 bg-light-subtle">
                    <div class="row g-3">

                        @* Especialidad *@
                        <div class="col-md-8">
                            <div class="form-floating shadow-sm">
                                <select id="cboEspecialidad" class="form-select border-0 px-3">
                                    <option value="">Seleccione una especialidad...</option>
                                </select>
                                <label class="small text-muted"><i class="bi bi-stethoscope me-1"></i>Especialidad</label>
                            </div>
                        </div>

                        @* Estado Disponibilidad *@
                        <div class="col-md-4">
                            <div class="card shadow-sm border-0 h-100 d-flex align-items-center justify-content-center bg-white px-3">
                                <div class="form-check form-switch p-0 m-0 d-flex align-items-center gap-3">
                                    <label class="form-check-label small fw-bold text-muted" for="chkActivo" id="lblEstadoTexto">DISPONIBLE</label>
                                    <input class="form-check-input ms-0" type="checkbox" role="switch" id="chkActivo" checked
                                           style="width: 2.5em; height: 1.25em; cursor: pointer;">
                                </div>
                            </div>
                        </div>

                        @* Número de Licencia *@
                        <div class="col-md-6">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtNumeroLicencia", null, new { @class = "form-control border-0 px-3", placeholder = "Licencia", inputmode = "numeric",maxlength="7"})
                                <label class="small text-muted"><i class="bi bi-card-text me-1"></i>Número de Licencia</label>
                            </div>
                        </div>

                        @* Consultorio *@
                        <div class="col-md-6">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtConsultorio", null, new { @class = "form-control border-0 px-3", placeholder = "Consultorio" })
                                <label class="small text-muted"><i class="bi bi-door-open me-1"></i>Consultorio</label>
                            </div>
                        </div>

                        @* Horarios *@
                        <div class="col-md-6">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtHoraEntrada", null, new { @class = "form-control border-0 px-3", type = "time" })
                                <label class="small text-muted"><i class="bi bi-clock me-1"></i>Hora de Entrada</label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtHoraSalida", null, new { @class = "form-control border-0 px-3", type = "time" })
                                <label class="small text-muted"><i class="bi bi-clock-fill me-1"></i>Hora de Salida</label>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            @* Acciones *@
            <div class="modal-footer bg-white border-0 py-3 px-4">
                <button type="button" class="btn btn-link text-muted text-decoration-none fw-semibold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" onclick="guardar()">
                    Guardar
                </button>
            </div>
        </div>
    </div>
</div>


@* Modal para ver detalles del Médico por ID *@
<div class="modal fade" id="modalDetallesMedico" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="modal-header bg-dark text-white py-3 px-4 border-0">
                <h6 class="modal-title fw-bold text-uppercase mb-0">
                    <i class="bi bi-person-vcard me-2"></i>Perfil Profesional del Médico
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                @* Fila Principal: Nombre y Especialidad *@
                <div class="row align-items-center mb-4 g-3">
                    <div class="col-md-8">
                        <div class="d-flex align-items-center">
                            <div>
                                <h3 class="fw-bold mb-0 text-dark">
                                    <span id="lblNombreMedico"></span> <span id="lblApellidoMedico"></span>
                                </h3>
                                <div class="d-flex gap-2 align-items-center mt-1">
                                    <span id="lblEspecialidad" class="badge bg-secondary px-3 py-2 rounded-pill"></span>
                                    <span class="text-muted small">| ID: <span id="lblIdMedico"></span></span>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-4 text-md-end text-start">
                        <label class="d-block small text-muted fw-bold mb-1">DISPONIBILIDAD</label>
                        <div id="statusMedico"></div> @* Se llenará dinámicamente: Disponible/Ocupado *@
                    </div>
                </div>

                <div class="row g-3">
                    @* Columna 1: Datos Laborales *@
                    <div class="col-md-4">
                        <div class="card h-100 border-0 bg-light shadow-sm">
                            <div class="card-body p-3">
                                <p class="small fw-bold text-uppercase mb-3 border-bottom pb-1">Información Laboral</p>
                                <div class="mb-3">
                                    <label class="d-block small text-muted">No. Licencia</label>
                                    <strong id="lblLicencia" class="text-dark"></strong>
                                </div>
                                <div class="mb-0">
                                    <label class="d-block small text-muted">Consultorio</label>
                                    <strong id="lblConsultorio" class="text-dark"></strong>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Columna 2: Horarios *@
                    <div class="col-md-4">
                        <div class="card h-100 border-0 bg-light shadow-sm">
                            <div class="card-body p-3">
                                <p class="small fw-bold text-uppercase mb-3 border-bottom pb-1">Horario de Atención</p>
                                <div class="d-flex align-items-center mb-3">
                                    <i class="bi bi-clock me-2 text-success"></i>
                                    <div>
                                        <label class="d-block small text-muted">Entrada</label>
                                        <strong id="lblHoraEntrada" class="text-dark"></strong>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center">
                                    <i class="bi bi-clock-fill me-2 text-danger"></i>
                                    <div>
                                        <label class="d-block small text-muted">Salida</label>
                                        <strong id="lblHoraSalida" class="text-dark"></strong>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Columna 3: Contacto *@
                    <div class="col-md-4">
                        <div class="card h-100 border-0 bg-light shadow-sm">
                            <div class="card-body p-3">
                                <p class="small fw-bold text-uppercase mb-3 border-bottom pb-1">Contacto</p>
                                <div class="mb-3">
                                    <label class="d-block small text-muted"><i class="bi bi-telephone me-1"></i>Teléfono</label>
                                    <strong id="lblTelefono" class="text-dark"></strong>
                                </div>
                                <div class="mb-0">
                                    <label class="d-block small text-muted"><i class="bi bi-envelope me-1"></i>Email</label>
                                    <div id="lblEmail" class="small text-dark fw-bold text-truncate"></div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer bg-white border-0 py-3">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@* Modal Confirmar Baja de Médico *@
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="modal-header bg-danger text-white py-3 px-4 border-0">
                <h6 class="modal-title fw-bold small text-uppercase mb-0">
                    <i class="bi bi-exclamation-octagon me-2"></i>Confirmar Baja
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4 text-center">
                <div class="mb-3">
                    <i class="bi bi-person-x-fill text-danger" style="font-size: 4rem; opacity: 0.8;"></i>
                </div>

                <h5 class="fw-bold text-dark">¿Desactivar este médico?</h5>
                <p class="text-muted small px-3">El médico no podrá ser asignado a nuevas citas.</p>

                @* Tarjeta de Resumen del Médico *@
                <div class="row g-0 border rounded-3 text-start mt-4 shadow-sm overflow-hidden">
                    <div class="col-3 bg-light border-end d-flex flex-column justify-content-center align-items-center p-2">
                        <small class="text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">ID Médico</small>
                        <span class="h5 fw-bold text-danger mb-0" id="EliminarId"></span>
                    </div>
                    <div class="col-9 p-3 bg-white">
                        <small class="text-muted fw-bold text-uppercase d-block" style="font-size: 0.65rem;">Nombre del Especialista</small>
                        <h6 class="fw-bold mb-1">
                            <span id="EliminarNombre"></span> <span id="EliminarApellido"></span>
                        </h6>
                        <div class="d-flex align-items-center">
                            <span id="EliminarEspecialidad" class="text-secondary small fw-semibold"></span>
                        </div>
                    </div>
                </div>

                @* Campo oculto para el ID *@
                <input type="hidden" id="hiddenIdEliminar" />
            </div>

            <div class="modal-footer bg-light py-3 border-top-0 d-flex justify-content-between px-4">
                <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold small" data-bs-dismiss="modal">
                    CANCELAR
                </button>
                <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm" onclick="confirmarEliminar()">
                    <i class="bi bi-trash3 me-1"></i> Confirmar Baja
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        let vistaActual = "ACTIVOS";

        $(document).ready(function () {
            cargarDatos();
            cargarSelects();

            $("#txtNumeroLicencia").on("input", function () {
                let valor = $(this).val().replace(/\D/g, "");

                if (valor.length > 7) {
                    valor = valor.substring(0, 7);
                }

                $(this).val(valor);
            });

        });

        document.getElementById('chkActivo').addEventListener('change', function () {
            const lbl = document.getElementById('lblEstadoTexto');
            if (this.checked) {
                lbl.innerText = "DISPONIBLE";
                lbl.className = "form-check-label small fw-bold text-success";
            } else {
                lbl.innerText = "OCUPADO";
                lbl.className = "form-check-label small fw-bold text-danger";
            }
        });

        //CARGAR MÉDICOS ACTIVOS
        function cargarDatos() {
            vistaActual = "ACTIVOS";
            $("#btnAgregar").prop("disabled", false); // Habilitar botón agregar
            $("#tituloVista").text("Listado de Médicos");

            ejecutarCarga('@Url.Action("Listar", "Medicos")');
        }

        //CARGAR HISTORIAL (INACTIVOS)
        function cargarDatosHistorial() {
            vistaActual = "HISTORIAL";
            $("#btnAgregar").prop("disabled", true); // Deshabilitar agregar en historial
            $("#tituloVista").text("Historial de Médicos Inactivos");

            ejecutarCarga('@Url.Action("ListarHistorial", "Medicos")');
        }

        // Función auxiliar para evitar repetir código de AJAX
        function ejecutarCarga(urlDestino) {
            $("#tablaMedicos tbody").html("<tr><td colspan='7' class='text-center py-4'><div class='spinner-border spinner-border-sm text-primary'></div> Cargando...</td></tr>");

            $.ajax({
                url: urlDestino,
                type: "GET",
                dataType: "json",
                success: function (data) {
                    llenarTabla(data);
                }
            });
        }

        // FUNCIÓN PARA CARGAR INFORMACIÓN DE MÉDICOS (TABLA)
        function llenarTabla(data) {
            var html = "";

            const esHistorial = (vistaActual === "HISTORIAL");
            const disabledAttr = esHistorial ? "disabled" : "";
            const opacityClass = esHistorial ? "opacity-50" : "";

            if (!data || data.length === 0) {
                html = "<tr><td colspan='7' class='text-center py-4 text-muted'>No hay registros en esta sección</td></tr>";
            } else {
                $.each(data, function (i, item) {
                    let badgeColor = item.Activo ? "bg-success" : "bg-danger";
                    let estadoTexto = item.Activo ? "Disponible" : "Ocupado";

                    let entrada = formatearHoraJS(item.HoraEntrada);
                    let salida = formatearHoraJS(item.HoraSalida);
                    let itemString = JSON.stringify(item).replace(/"/g, '&quot;');

                    html += `<tr>
                        <td class='ps-4'>
                            <div class='d-flex flex-column'>
                                <span class='fw-bold text-dark'>${item.MedicoNombre} ${item.MedicoApellido}</span>
                                <small class='text-muted'>J.V.P.M: ${item.NumeroLicencia}</small>
                            </div>
                        </td>
                        <td><span class='badge bg-light text-dark border'><i class='bi bi-clock me-1'></i>${entrada} - ${salida}</span></td>
                        <td><span class='fw-semibold'>${item.MedicoEspecialidad}</span></td>
                        <td>${item.Consultorio || "N/A"}</td>
                        <td><span class='text-muted'>${item.MedicoTelefono || "---"}</span></td>
                        <td><span class='badge ${badgeColor} py-2 fw-bold' style='width: 90px;'>${estadoTexto}</span></td>
                        <td class='pe-4 text-center'>
                            <div class='btn-group shadow-sm'>
                                <button class='btn btn-light btn-sm text-primary' ${disabledAttr} onclick='abrirModal(${itemString})'><i class='bi bi-pencil'></i></button>
                                <button class='btn btn-light btn-sm text-secondary' ${disabledAttr} onclick='consultarDetalles(${item.MedicoID})'><i class='bi bi-eye'></i></button>
                                <button class='btn btn-light btn-sm text-danger' ${disabledAttr} onclick='eliminar(${item.MedicoID})'><i class='bi bi-person-x'></i></button>
                            </div>
                        </td>
                    </tr>`;
                });
            }
            $("#tablaMedicos tbody").html(html);
        }

        // FUNCIÓN PARA LLENAR LOS SELECT
        function cargarSelects() {
            $.get('@Url.Action("ObtenerEspecialidadesActivas", "Medicos")', function (data) {
                let html = '<option value="">-- Seleccione una Especialidad --</option>';
                $.each(data, function (i, item) {
                    html += `<option value="${item.Id}">${item.Nombre}</option>`;
                });
                $("#cboEspecialidad").html(html);
            });

            $.get('@Url.Action("ListarUsuariosMedicos", "Medicos")', function (data) {
                let html = '<option value="">-- Seleccione el nombre del médico --</option>';
                $.each(data, function (i, item) {
                    html += `<option value="${item.UsuarioID}">${item.NombreCompleto}</option>`;
                });
                $("#cboUsuario").html(html);
            });

        }

        // FUNCIÓN PARA ABRIR MODAL (AGREGAR/MODIFICAR)
        function abrirModal(medico) {
            const lblEstado = $("#lblEstadoTexto");

            if (medico == null) {
                $("#txtIdMedico").val(0);

                $("#cboUsuario").val("").prop("disabled", false);

                $("#cboEspecialidad").val("");
                $("#txtNumeroLicencia").val("");
                $("#txtConsultorio").val("");
                $("#txtHoraEntrada").val("08:00");
                $("#txtHoraSalida").val("16:00");

                $("#chkActivo").prop("checked", true);
                lblEstado.text("DISPONIBLE").removeClass("text-danger").addClass("text-success");

                $("#lblNombreLectura").text("Nuevo Registro");

            } else {
                $("#txtIdMedico").val(medico.MedicoID);
                $("#txtNumeroLicencia").val(medico.NumeroLicencia);
                $("#txtConsultorio").val(medico.Consultorio);

                $("#chkActivo").prop("checked", medico.Activo);
                if (medico.Activo) {
                    lblEstado.text("DISPONIBLE").removeClass("text-danger").addClass("text-success");
                } else {
                    lblEstado.text("OCUPADO").removeClass("text-success").addClass("text-danger");
                }

                $("#txtHoraEntrada").val(formatearHoraJS(medico.HoraEntrada));
                $("#txtHoraSalida").val(formatearHoraJS(medico.HoraSalida));

                setTimeout(function () {

                    if ($("#cboUsuario option[value='" + medico.UsuarioID + "']").length === 0) {
                        $("#cboUsuario").append($('<option>', {
                            value: medico.UsuarioID,
                            text: medico.MedicoNombre + " " + medico.MedicoApellido
                        }));
                    }

                    $("#cboUsuario").val(medico.UsuarioID).prop("disabled", true);

                    if (medico.EspecialidadID) {
                        $("#cboEspecialidad").val(medico.EspecialidadID);
                    }

                }, 150);
            }
            $('#modalMedico').modal('show');
        }


        // FUNCIÓN PARA GUARDAR INFORMACIÓN (AGREGAR/MODIFICAR)
        function guardar() {
            var numero = $("#txtNumeroLicencia").val();

            var request = {
                MedicoID: parseInt($("#txtIdMedico").val()),
                UsuarioID: $("#cboUsuario").val(),
                EspecialidadID: $("#cboEspecialidad").val(),
                NumeroLicencia: $("#txtNumeroLicencia").val(),
                Consultorio: $("#txtConsultorio").val(),
                HoraEntrada: $("#txtHoraEntrada").val(),
                HoraSalida: $("#txtHoraSalida").val(),
                Activo: $("#chkActivo").prop("checked")
            };

            $.ajax({
                url: '@Url.Action("Guardar", "Medicos")',
                type: "POST",
                data: JSON.stringify(request),
                contentType: "application/json; charset=utf-8",
                success: function (response) {

                    if (response.success) {

                        Swal.fire({
                            icon: 'success',
                            title: 'Guardado',
                            text: 'El médico se guardó correctamente',
                            confirmButtonText: 'OK'
                        }).then(() => {
                            $('#modalMedico').modal('hide');
                            vistaActual === "HISTORIAL" ? cargarDatosHistorial() : cargarDatos();
                        });

                    } else {

                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.mensaje,
                            confirmButtonText: 'Entendido'
                        });

                    }
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error inesperado',
                        text: 'No se pudo completar la operación'
                    });
                }
            });
        }

        // FUNCIÓN PARA OBTENER INFORMACIÓN DE MÉDICO A ELIMINAR
        function eliminar(id) {
            $.get('@Url.Action("Consultar", "Medicos")', { id: id }, function (response) {
                if (response.success) {
                    var m = response.data;
                    $("#EliminarNombre").text(m.MedicoNombre);
                    $("#EliminarApellido").text(m.MedicoApellido);
                    $("#EliminarEspecialidad").text(m.MedicoEspecialidad);
                    $("#EliminarId").text(m.MedicoID);
                    $("#hiddenIdEliminar").val(m.UsuarioID); //Id para activo = false en tabla usuarios
                    $("#modalEliminar").modal("show");
                }
            });
        }


        // FUNCIÓN PARA ELIMINAR/INHABILITAR (ELIMINADO LÓGICO)
        function confirmarEliminar() {
            var id = $("#hiddenIdEliminar").val();
            $.post('@Url.Action("Eliminar", "Medicos")', { id: id }, function (response) {
                if (response.success) {
                    $("#modalEliminar").modal("hide");
                    cargarDatos();
                }
            });
        }


        // FUNCIÓN PARA VER DETALLES DE MÉDICO POR ID
        function consultarDetalles(id) {
            $.get('@Url.Action("Consultar", "Medicos")', { id: id }, function (response) {
                if (response.success) {
                    const m = response.data;
                    $("#lblNombreMedico").text(m.MedicoNombre);
                    $("#lblApellidoMedico").text(m.MedicoApellido);
                    $("#lblEspecialidad").text(m.MedicoEspecialidad);
                    $("#lblIdMedico").text(m.MedicoID);
                    $("#lblLicencia").text(m.NumeroLicencia);
                    $("#lblConsultorio").text(m.Consultorio);
                    $("#lblHoraEntrada").text(formatearHoraJS(m.HoraEntrada));
                    $("#lblHoraSalida").text(formatearHoraJS(m.HoraSalida));
                    $("#lblTelefono").text(m.MedicoTelefono || "---");
                    $("#lblEmail").text(m.MedicoEmail || "---");
                    let statusHtml = m.Activo ? '<span class="badge bg-success fs-6 w-100 py-2">DISPONIBLE</span>' : '<span class="badge bg-danger fs-6 w-100 py-2">OCUPADO</span>';
                    $("#statusMedico").html(statusHtml);
                    $("#modalDetallesMedico").modal("show");
                }
            });
        }


        //FUNCIÓN PARA DAR FORMATO A HORA
        function formatearHoraJS(hora) {
            if (!hora) return "00:00";
            if (hora.Hours !== undefined) return ("0" + hora.Hours).slice(-2) + ":" + ("0" + hora.Minutes).slice(-2);
            return hora.substring(0, 5);
        }
    </script>
}

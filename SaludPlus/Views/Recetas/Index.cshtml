@{
    ViewBag.Title = "Despacho de Recetas";
}

<div class="container-fluid mt-4 px-4 mb-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold text-dark mb-1"><i class="fas fa-prescription-bottle-alt text-primary me-2"></i>Módulo de Farmacia</h4>
            <p class="text-muted mb-0 small">Gestión y despacho de recetas médicas emitidas en clínica.</p>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table align-middle table-hover mb-0" id="tablaRecetas">
                    <thead class="table-light">
                        <tr>
                            <th class="ps-4">N° Receta</th>
                            <th>Fecha de Emisión</th>
                            <th>Paciente</th>
                            <th>Médico Tratante</th>
                            <th>Ítems</th>
                            <th>Estado</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="modalDetalleReceta" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4 shadow-lg">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title fw-bold"><i class="fas fa-file-medical me-2"></i>Despacho de Receta <span id="lblNumeroReceta"></span></h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 bg-light">
                <input type="hidden" id="hdnRecetaID" />
                <div class="row g-3 mb-4">
                    <div class="col-md-6">
                        <label class="text-muted small fw-bold text-uppercase">Paciente</label>
                        <h6 class="fw-bold mb-0 text-dark" id="lblPaciente">--</h6>
                    </div>
                    <div class="col-md-6 text-md-end">
                        <label class="text-muted small fw-bold text-uppercase">Médico Tratante</label>
                        <h6 class="fw-bold mb-0 text-dark" id="lblMedico">--</h6>
                    </div>
                </div>
                <div class="card border-0 shadow-sm">
                    <div class="card-header bg-white fw-bold text-primary py-3">
                        <i class="fas fa-box-open me-2"></i>Productos a Entregar
                    </div>
                    <div class="table-responsive">
                        <table class="table table-sm align-middle mb-0" id="tablaDetalles">
                            <thead class="table-light">
                                <tr>
                                    <th class="ps-3">Medicamento</th>
                                    <th>Dosis</th>
                                    <th class="text-center">Cant.</th>
                                    <th>Indicaciones (Imprimir en viñeta)</th>
                                    <th class="text-center">Estado</th>
                                </tr>
                            </thead>
                            <tbody>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-white border-top-0 pt-0 pb-3 pe-4">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- Modal de Confirmación de Entrega -->
<div class="modal fade" id="modalConfirmarEntrega" tabindex="-1" aria-hidden="true" style="z-index: 1060;">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content border-0 shadow-lg rounded-4">
            <div class="modal-body text-center p-4">
                <div class="text-success mb-3">
                    <i class="fas fa-hand-holding-medical fa-4x opacity-75"></i>
                </div>
                <h5 class="fw-bold text-dark mb-2">¿Confirmar Entrega?</h5>
                <p class="text-muted small mb-4">¿Estás seguro de que deseas registrar la entrega de este medicamento al paciente?</p>

                <!-- Campos ocultos para saber qué vamos a despachar -->
                <input type="hidden" id="hdnDetalleConfirmar" />
                <input type="hidden" id="hdnRecetaConfirmar" />

                <div class="d-flex justify-content-center gap-2">
                    <button type="button" class="btn btn-light border shadow-sm px-3" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-success shadow-sm px-4 fw-bold" onclick="ejecutarEntrega()">Sí, Entregar</button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
       $(document).ready(function () {
            cargarRecetas();
        });

        function formatearFecha(fechaJson) {
            if (!fechaJson) return "";
            var ms = parseInt(fechaJson.replace("/Date(", "").replace(")/", ""));
            var d = new Date(ms);
            return ("0" + d.getDate()).slice(-2) + "/" + ("0" + (d.getMonth() + 1)).slice(-2) + "/" + d.getFullYear() + " " +
                   ("0" + d.getHours()).slice(-2) + ":" + ("0" + d.getMinutes()).slice(-2);
        }

        function cargarRecetas() {
            $.get('@Url.Action("Listar", "Recetas")', function (data) {
                var html = "";

                if(data.length === 0) {
                    html = "<tr><td colspan='7' class='text-center py-4 text-muted'>No hay recetas registradas.</td></tr>";
                }

                $.each(data, function (i, item) {
                    let badgeColor = "bg-secondary";
                    let estadoPrincipal = item.Estado ? item.Estado.toString().trim() : "Pendiente";
                    let estadoEvaluar = estadoPrincipal.toLowerCase();

                    if (estadoEvaluar === "emitida" || estadoEvaluar === "pendiente") badgeColor = "bg-warning text-dark";
                    if (estadoEvaluar === "dispensada" || estadoEvaluar === "despachada") badgeColor = "bg-success";
                    if (estadoEvaluar === "vencida" || estadoEvaluar === "anulada") badgeColor = "bg-danger";

                    let btnDetalles = `<button class='btn btn-light btn-sm text-primary shadow-sm border me-1' title='Ver medicamentos' onclick='verDetalles(${item.RecetaID})'><i class='fas fa-eye'></i> Ver</button>`;

                    html += `<tr>
                        <td class='ps-4 fw-bold text-primary'>#REC-${item.RecetaID.toString().padStart(4, '0')}</td>
                        <td class='text-muted small'>${formatearFecha(item.FechaEmision)}</td>
                        <td><h6 class='mb-0 fw-bold fs-6'>${item.PacienteNombre}</h6></td>
                        <td class='text-muted small'>Dr. ${item.MedicoNombre}</td>
                        <td><span class='badge bg-light text-dark border'>${item.TotalMedicamentos} prod.</span></td>
                        <td><span class='badge ${badgeColor} px-2 py-1'>${estadoPrincipal}</span></td>
                        <td class='text-center pe-4'>${btnDetalles}</td>
                    </tr>`;
                });

                $("#tablaRecetas tbody").html(html);
            });
        }

        function verDetalles(idReceta) {
            $.get('/Recetas/ConsultarDetalle?id=' + idReceta, function (res) {
                if (res.success) {
                    $("#hdnRecetaID").val(res.header.RecetaID);
                    $("#lblNumeroReceta").text("#REC-" + res.header.RecetaID.toString().padStart(4, '0'));
                    $("#lblPaciente").text(res.header.Paciente);
                    $("#lblMedico").text(res.header.Medico);

                    let html = "";
                    $.each(res.detalles, function (i, item) {

                        let nombreMed = item.Medicamento;
                        if (item.EsComodin) {
                            nombreMed = "<span class='text-danger fw-bold'><i class='fas fa-exclamation-triangle'></i> MEDICAMENTO EXTERNO</span>";
                        }

                        // LÓGICA BOOLEANA DEFINITIVA: Si es true (1), está entregada.
                        let isDispensada = (item.Estado === true || item.Estado === 'true' || item.Estado === 1);

                        let estadoHtml = "";
                        if (isDispensada) {
                            estadoHtml = `<span class="badge bg-success"><i class="fas fa-check-double me-1"></i> Entregado</span>`;
                        } else {
                            estadoHtml = `<button class="btn btn-sm btn-success shadow-sm" onclick="marcarDetalle(${item.DetalleID}, ${res.header.RecetaID})">
                                            <i class="fas fa-hand-holding-medical me-1"></i> Entregar
                                          </button>`;
                        }

                        html += `<tr>
                                    <td class='ps-3 fw-bold'>${nombreMed}</td>
                                    <td>${item.Dosis}</td>
                                    <td class='text-center fw-bold fs-5'>${item.Cantidad}</td>
                                    <td class='text-muted small'>${item.Indicaciones}</td>
                                    <td class='text-center'>${estadoHtml}</td>
                                 </tr>`;
                    });

                    $("#tablaDetalles tbody").html(html);
                    $('#modalDetalleReceta').modal('show');
                } else {
                    alert("Error al obtener detalles: " + res.mensaje);
                }
            });
        }

        function marcarDetalle(idDetalle, idReceta) {

            // 1. Lanzamos la pregunta hermosa
            Swal.fire({
                title: '¿Confirmar Entrega?',
                text: "¿Estás seguro de registrar la entrega de este medicamento al paciente?",
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#198754',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, Entregar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {

                // 2. Si el farmacéutico le dio a "Sí"
                if (result.isConfirmed) {
                    $.post(`/Recetas/DespacharDetalle?idDetalle=${idDetalle}&idReceta=${idReceta}`, function (res) {
                        if (res.success) {
                            if (res.completada) {
                                // Alerta de Receta 100% Finalizada
                                Swal.fire({
                                    icon: 'success',
                                    title: '¡Receta Completada!',
                                    text: 'Todos los medicamentos han sido entregados.',
                                    confirmButtonColor: '#198754'
                                });
                                $('#modalDetalleReceta').modal('hide');
                                cargarRecetas();
                            } else {
                                // Aún faltan medicinas, recargamos el modal en silencio
                                verDetalles(idReceta);
                                cargarRecetas();
                            }
                        } else {
                            Swal.fire('Error', res.mensaje, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
@{
    ViewBag.Title = "Gestión de Pacientes";
}

<link href="@Url.Content("~/Content/styles/Admin.css")" rel="stylesheet" />


@* Cards presentación de pacientes *@
<div class="container-fluid mt-4 px-4">
    <div class="card shadow-sm border-0 rounded-4 mb-4">
        <div class="card-header bg-white border-bottom-0 py-3 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3 rounded-top-4">
            <h5 id="tituloVista" class="fw-bold mb-0 text-dark">Listado de Pacientes</h5>

            <div class="d-flex gap-2 justify-content-center">
                <button id="btnAgregar" class="btn btn-primary btn-sm px-3 shadow-sm" onclick="abrirModal(null)">
                    <i class="bi bi-plus-lg me-1"></i> Agregar
                </button>
                <button class="btn btn-outline-secondary btn-sm px-3" onclick="cargarDatosHistorial()">
                    <i class="fas fa-history me-1"></i> Historial
                </button>
                <button class="btn btn-light btn-sm px-2 border shadow-sm" onclick="cargarDatos()" title="Refrescar">
                    <i class="fas fa-arrow-left text-primary"></i>
                </button>
            </div>
        </div>
    </div>

    <div class="row g-4" id="contenedorPacientes">
        @* Llenado con AJAX*@
    </div>
</div>

@* Modal para registro/modificación *@
<div class="modal fade" id="modalPaciente" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="modal-header bg-dark text-white border-0 py-3 px-4">
                <h6 class="modal-title d-flex align-items-center fw-bold">
                    <i class="bi bi-person-badge-fill me-2 fs-5"></i>
                    INFORMACIÓN DE PACIENTE
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-0">
                @Html.Hidden("txtIdPaciente", "0")

                <div class="container-fluid py-4 px-4 bg-light-subtle">
                    <div class="row g-2">

                        @* --- SECCIÓN IDENTIDAD --- *@
                        <div class="col-12 mb-1">
                            <span class="badge bg-primary-subtle text-primary text-uppercase px-2" style="font-size: 0.65rem; letter-spacing: 1px;">Identidad</span>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtNombre", null, new { @class = "form-control border-0 px-3", placeholder = "Nombre" })
                                <label class="small text-muted"><i class="bi bi-person me-1"></i>Nombre</label>
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtApellido", null, new { @class = "form-control border-0 px-3", placeholder = "Apellido" })
                                <label class="small text-muted"><i class="bi bi-person me-1"></i>Apellido</label>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-6">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtDui", null, new { @class = "form-control border-0 px-3", placeholder = "DUI" })
                                <label class="small text-muted"><i class="bi bi-card-text me-1"></i>DUI</label>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-6">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtFechaNac", null, new { @class = "form-control border-0 px-3", type = "date" })
                                <label class="small text-muted"><i class="bi bi-calendar-event me-1"></i>Nacimiento</label>
                            </div>
                        </div>

                        <div class="col-md-4 col-sm-12">
                            <div class="form-floating shadow-sm">
                                @Html.DropDownList("txtSexo", new List<SelectListItem> {
                                    new SelectListItem { Text = "Masculino", Value = "M" },
                                    new SelectListItem { Text = "Femenino", Value = "F" }
                                }, "Seleccione...", new { @class = "form-select border-0 px-3" })
                                <label class="small text-muted"><i class="bi bi-gender-ambiguous me-1"></i>Género</label>
                            </div>
                        </div>

                        @* --- SECCIÓN CONTACTO --- *@
                        <div class="col-12 mt-3 mb-1">
                            <span class="badge bg-success-subtle text-success text-uppercase px-2" style="font-size: 0.65rem; letter-spacing: 1px;">Contacto</span>
                        </div>

                        <div class="col-md-4">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtTelefono", null, new { @class = "form-control border-0 px-3", type = "tel", placeholder = "Tel" })
                                <label class="small text-muted"><i class="bi bi-telephone me-1"></i>Teléfono</label>
                            </div>
                        </div>

                        <div class="col-md-8">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtEmail", null, new { @class = "form-control border-0 px-3", type = "email", placeholder = "Email" })
                                <label class="small text-muted"><i class="bi bi-envelope me-1"></i>Email</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-floating shadow-sm">
                                @Html.TextArea("txtDireccion", null, new { @class = "form-control border-0 px-3", style = "height: 60px", placeholder = "Dirección" })
                                <label class="small text-muted"><i class="bi bi-geo-alt me-1"></i>Dirección Completa</label>
                            </div>
                        </div>

                        @* --- SECCIÓN CLÍNICA --- *@
                        <div class="col-12 mt-3 mb-1 d-flex justify-content-between align-items-center">
                            <span class="badge bg-danger-subtle text-danger text-uppercase px-2" style="font-size: 0.65rem; letter-spacing: 1px;">Expediente Médico</span>
                            <div class="form-check form-switch small">
                                <label class="form-check-label text-muted" for="txtActivo">Activo</label>
                                <input class="form-check-input" type="checkbox" id="txtActivo" checked>
                            </div>
                        </div>

                        <div class="col-md-3">
                            <div class="form-floating shadow-sm">
                                @Html.DropDownList("txtTipoSangre", new List<SelectListItem> {
                                    new SelectListItem { Text = "O+", Value = "O+" }, new SelectListItem { Text = "O-", Value = "O-" },
                                    new SelectListItem { Text = "A+", Value = "A+" }, new SelectListItem { Text = "A-", Value = "A-" },
                                    new SelectListItem { Text = "B+", Value = "B+" }, new SelectListItem { Text = "B-", Value = "B-" },
                                    new SelectListItem { Text = "AB+", Value = "AB+" }, new SelectListItem { Text = "AB-", Value = "AB-" }
                                }, "---", new { @class = "form-select border-0 px-3" })
                                <label class="small text-muted"><i class="bi bi-droplet me-1"></i>Sangre</label>
                            </div>
                        </div>

                        <div class="col-md-9">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtAlergias", null, new { @class = "form-control border-0 px-3", placeholder = "Alergias" })
                                <label class="small text-muted"><i class="bi bi-exclamation-triangle me-1"></i>Alergias conocidas</label>
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-floating shadow-sm">
                                @Html.TextArea("txtAntecedentes", null, new { @class = "form-control border-0 px-3", style = "height: 60px", placeholder = "Antecedentes" })
                                <label class="small text-muted"><i class="bi bi-journal-medical me-1"></i>Antecedentes relevantes</label>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="modal-footer bg-white border-0 py-3 px-4">
                <button type="button" class="btn btn-link text-muted text-decoration-none fw-semibold" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" class="btn btn-success rounded-pill px-4 shadow-sm fw-bold" onclick="guardar()">
                    <i class="bi bi-check2-circle me-1"></i> Guardar
                </button>
            </div>
        </div>
    </div>
</div>


@* Modal para ver detalles por ID *@
<div class="modal fade" id="modalDetalles" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-dark text-white py-2 px-3">
                <h6 class="modal-title fw-bold small text-uppercase mb-0">Ficha de Urgencia</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3">
                <div class="row align-items-center mb-3 g-2">
                    <div class="col-8">
                        <h4 class="fw-bold mb-0 text-dark"><span id="lblNombreCompleto"></span></h4>
                        <small class="text-muted fw-normal" style="font-size: 0.9rem;">No. <span id="lblIdPaciente"></span></small>
                        <div class="d-flex gap-2 align-items-center">
                            <span id="lblDui" class="badge bg-light text-dark border"></span>
                        </div>
                    </div>
                    <div class="col-4 text-end">
                        <label class="d-block small text-muted fw-bold mb-0">SANGRE</label>
                        <span id="lblTipoSangre" class="badge bg-danger fs-5 w-100 py-2"></span>
                    </div>
                </div>
                <div class="row g-2">
                    <div class="col-md-4">
                        <ul class="list-group list-group-flush border rounded-3 h-100">
                            <li class="list-group-item py-1 bg-light small fw-bold text-muted text-uppercase">Información Personal</li>
                            <li class="list-group-item py-1 small"><strong>Nacimiento:</strong> <span id="lblFechaNac"></span></li>
                            <li class="list-group-item py-1 small"><strong>Sexo:</strong> <span id="lblSexo"></span></li>
                            <li class="list-group-item py-1 small"><strong>Estado:</strong> <span id="lblEstado"></span></li>
                            <li class="list-group-item py-1 small"><strong>Ingreso:</strong> <span id="lblFechaRegistro"></span></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <ul class="list-group list-group-flush border rounded-3 h-100">
                            <li class="list-group-item py-1 bg-light small fw-bold text-muted text-uppercase">Contacto</li>
                            <li class="list-group-item py-1 small"><strong>Tel:</strong> <span id="lblTelefono"></span></li>
                            <li class="list-group-item py-1 small text-truncate"><strong>Email:</strong> <span id="lblEmail"></span></li>
                            <li class="list-group-item py-1 small"><strong>Dirección:</strong> <p id="lblDireccion" class="mb-0 lh-sm" style="font-size: 0.75rem;"></p></li>
                        </ul>
                    </div>
                    <div class="col-md-4">
                        <div class="border rounded-3 h-100">
                            <div class="p-2 bg-warning-subtle border-bottom small fw-bold text-warning-emphasis text-uppercase text-center">Alergias</div>
                            <div class="p-2 small text-dark" id="lblAlergias" style="min-height: 40px;"></div>
                            <div class="p-2 bg-primary-subtle border-top border-bottom small fw-bold text-primary-emphasis text-uppercase text-center">Antecedentes</div>
                            <div class="p-2 small text-dark" id="lblAntecedentes"></div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="modal-footer py-1 border-top-0">
                <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@* Modal Eliminar *@
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-danger text-white py-2 px-3">
                <h6 class="modal-title fw-bold small text-uppercase mb-0">Confirmar Baja</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4 text-center">
                <i class="fas fa-exclamation-circle text-danger mb-2" style="font-size: 3rem;"></i>
                <h5 class="fw-bold text-dark">¿Desactivar este registro?</h5>
                <p class="text-muted small">El paciente dejará de aparecer en las listas activas.</p>
                <div class="row g-0 border rounded-3 text-start">
                    <div class="col-4 bg-light border-end p-3 text-center">
                        <small class="text-muted fw-bold text-uppercase d-block" style="font-size: 0.7rem;">ID</small>
                        <span class="h5 fw-bold text-dark" id="EliminarId"></span>
                    </div>
                    <div class="col-8 p-3 bg-white">
                        <small class="text-muted fw-bold text-uppercase d-block" style="font-size: 0.7rem;">Paciente</small>
                        <h6 class="fw-bold" id="EliminarNombre"></h6>
                        <span id="EliminarDui" class="badge bg-light text-dark border fw-normal"></span>
                    </div>
                </div>
                <input type="hidden" id="hiddenIdEliminar" />
            </div>
            <div class="modal-footer bg-light py-2 border-top-0 d-flex justify-content-between">
                <button type="button" class="btn btn-sm btn-link text-muted text-decoration-none fw-bold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-sm btn-danger px-4 fw-bold shadow-sm" onclick="confirmarEliminar()">Confirmar Baja</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Declaración de rutas dinámicas mediante Razor
        const UrlListar = '@Url.Action("Listar", "Pacientes")';
        const UrlHistorial = '@Url.Action("ListarHistorial", "Pacientes")';
        const UrlConsultar = '@Url.Action("Consultar", "Pacientes")';
        const UrlGuardar = '@Url.Action("Guardar", "Pacientes")';
        const UrlEliminar = '@Url.Action("Eliminar", "Pacientes")';

        $(document).ready(function () {
            cargarDatos();

            // FORMATO EN TIEMPO REAL
            //TELÉFONO
            $("#txtTelefono").on("input", function () {
                let valor = $(this).val().replace(/\D/g, "");

                if (valor.length > 8) {
                    valor = valor.substring(0, 8);
                }

                if (valor.length > 4) {
                    valor = valor.substring(0, 4) + "-" + valor.substring(4);
                }

                $(this).val(valor);
            });

            //DUI
            $("#txtDui").on("input", function () {
                let valor = $(this).val().replace(/\D/g, "");

                if (valor.length > 9) {
                    valor = valor.substring(0, 9);
                }

                if (valor.length > 8) {
                    valor = valor.substring(0, 8) + "-" + valor.substring(8);
                }

                $(this).val(valor);
            });
        });

        //Variable global de estados
        let vistaActual = "ACTIVOS";

        // Formato DD/MM/YYYY Para listados
        function formatearFecha(fechaJson) {
            if (!fechaJson) return "";

            // Extraer solo los números de la fecha que envía .NET: /Date(123456789)/
            var milisegundos = parseInt(fechaJson.replace("/Date(", "").replace(")/", ""));
            var fecha = new Date(milisegundos);

            // Formato YYYY-MM-DD
            return ("0" + fecha.getDate()).slice(-2) + "/" + ("0" + (fecha.getMonth() + 1)).slice(-2) + "/" + fecha.getFullYear();
        }

        // Función formato YYYY/MM/DD Para inputs
        function formatearFechaInput(fechaJson) {
            if (!fechaJson) return "";
            var milisegundos = parseInt(fechaJson.replace("/Date(", "").replace(")/", ""));
            var fecha = new Date(milisegundos);
            return fecha.getFullYear() + "-" + ("0" + (fecha.getMonth() + 1)).slice(-2) + "-" + ("0" + fecha.getDate()).slice(-2);
        }

        // Formato DD/MM/YYYY HH:MM Para fecha registro
        function formatearFechaHora(fechaJson) {
            if (!fechaJson) return "No registrada";
            var ms = parseInt(fechaJson.replace("/Date(", "").replace(")/", ""));
            var fecha = new Date(ms);
            return formatearFecha(fechaJson) + " " + ("0" + fecha.getHours()).slice(-2) + ":" + ("0" + fecha.getMinutes()).slice(-2);
        }

        // Función para mostrar texto según valor de sexo
        function formatearSexo(sexoJson) {
            return sexoJson === "M" ? "Masculino" : "Femenino";
        }

        // FORMATO TELÉFONO 0000-0000
        function formatearTelefono(numero) {
            numero = numero.replace(/\D/g, "");

            if (numero.length === 8) {
                return numero.substring(0, 4) + "-" + numero.substring(4);
            }

            return numero;
        }

        // FORMATO DUI 00000000-0
        function formatearDui(dui) {
            dui = dui.replace(/\D/g, "");

            if (dui.length === 9) {
                return dui.substring(0, 8) + "-" + dui.substring(8);
            }

            return dui;
        }

        // 1. FUNCION PARA LISTAR ACTIVOS
        function cargarDatos() {
            vistaActual = "ACTIVOS";
            $("#btnAgregar").prop("disabled", false);
            $("#tituloVista").text("Listado de Pacientes");

            $("#contenedorPacientes").html('<div class="col-12 text-center py-5"><div class="spinner-border text-primary"></div></div>');

            $.get(UrlListar, function (data) {
                llenarCards(data);
            });
        }

        // FUNCION PARA LISTAR INACTIVOS
        function cargarDatosHistorial() {
            vistaActual = "HISTORIAL";
            $("#btnAgregar").prop("disabled", true);
            $("#tituloVista").text("Historial de Pacientes");

            $("#contenedorPacientes").html('<div class="col-12 text-center py-5"><div class="spinner-border text-secondary"></div></div>');

            $.get(UrlHistorial, function (data) {
                llenarCards(data);
            });
        }

        // LLENADO DE CARDS CON INFORMACIÓN
        function llenarCards(data) {
            var html = "";

            $("#contenedorPacientes").empty();

            if (!data || data.length === 0) {
                html = `
                <div class="col-12 text-center py-5">
                    <div class="display-1 text-muted opacity-25"><i class="bi bi-people"></i></div>
                    <h6 class="text-muted mt-3 py-3 px-4 border rounded-pill d-inline-block bg-white shadow-sm">
                        No se encontraron pacientes en esta sección.
                    </h6>
                </div>`;
            } else {
                $.each(data, function (i, item) {
                    var inicial = item.Nombres ? item.Nombres.charAt(0) : "?";
                    var itemJson = JSON.stringify(item).replace(/"/g, '&quot;');

                    var esActivo = item.Activo;
                    var deshabilitado = !esActivo ? "disabled" : "";

                    html += `
                    <div class="col-12 col-md-6 col-lg-4">
                        <div class="card h-100 rounded-4 transition-hover overflow-hidden" style="background-color: #fdfdfd;">
                            <div class="card-body p-4 position-relative">
                                <div class="d-flex align-items-center mb-4">
                                    <div class="rounded-circle bg-primary-subtle text-primary d-flex align-items-center justify-content-center me-3 shadow-inner" style="width: 58px; height: 58px; font-weight: 700; font-size: 1.6rem;">
                                        ${inicial}
                                    </div>
                                    <div class="flex-grow-1">
                                        <h6 class="mb-0 fw-bold text-dark text-truncate">${item.Apellidos}</h6>
                                        <h6 class="mb-0 fw-bold text-dark text-truncate">${item.Nombres}</h6>
                                        <small class="text-muted d-block text-truncate">
                                            <i class="bi bi-card-text me-1"></i>DUI: ${item.DUI || "N/A"}
                                        </small>
                                    </div>
                                </div>
                                <div class="position-absolute top-0 end-0 mt-3 me-3">
                                    <span class="badge bg-danger border shadow-sm px-2 py-1">${item.TipoSangre || "N/A"}</span>
                                </div>
                                <div class="d-flex flex-row justify-content-between align-items-center gap-2">
                                    <div class="d-flex align-items-start flex-fill w-50">
                                        <div class="me-2 mt-1 fs-5 text-warning">
                                           <i class="bi bi-patch-exclamation"></i>
                                        </div>
                                        <div class="text-truncate">
                                            <small class="d-block text-muted fw-semibold text-uppercase" style="font-size: 0.7rem;">Alergias</small>
                                            <span class="small text-dark d-block fw-medium text-truncate" title="${item.Alergias || 'Sin registro'}">
                                                ${item.Alergias || "Sin registro"}
                                            </span>
                                        </div>
                                    </div>
                                    <div class="d-flex align-items-start flex-fill w-50">
                                        <div class="me-2 mt-1 fs-5 text-primary">
                                            <i class="bi bi-clipboard-pulse"></i>
                                        </div>
                                        <div class="text-truncate">
                                            <small class="d-block text-muted fw-semibold text-uppercase" style="font-size: 0.7rem;">Antecedentes</small>
                                            <span class="small text-dark d-block fw-medium text-truncate" title="${item.AntecedentesMedicos || 'Sin registro'}">
                                                ${item.AntecedentesMedicos || "Sin registro"}
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="card-footer bg-light border-0 px-4 py-3 d-flex justify-content-between align-items-center">
                                <div class="d-flex gap-1">
                                    <button class="btn btn-light btn-sm border shadow-sm rounded-pill" onclick='verDetalles(${item.PacienteID})'><i class="bi bi-eye"></i></button>
                                    <button class="btn btn-light btn-sm text-primary border shadow-sm rounded-pill" onclick='abrirModal(${itemJson})'><i class="bi bi-pencil"></i></button>
                                    <button class="btn btn-light btn-sm text-danger border shadow-sm rounded-pill ${deshabilitado}" onclick='eliminar(${item.PacienteID})' ${deshabilitado}><i class="bi bi-trash"></i></button>
                                </div>
                                <div class="d-flex align-items-center">
                                    <div class="rounded-circle ${esActivo ? 'bg-success' : 'bg-danger'}" style="width: 10px; height: 10px;"></div>
                                    <span class="ms-2 small fw-bold ${esActivo ? 'text-success' : 'text-danger'} text-uppercase" style="font-size: 0.75rem;">
                                        ${esActivo ? "Activo" : "Inactivo"}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>`;
                });
            }
            $("#contenedor_p").html(html);
            $("#contenedorPacientes").html(html);
        }

        // FUNCIÓN PARA VER DETALLES DE PACIENTES POR ID
        function verDetalles(id) {
            $.get(UrlConsultar, { id: id }, function (response) {
                if (response.success) {
                    var p = response.data;
                    $("#lblNombreCompleto").text(p.Nombres + " " + p.Apellidos);
                    $("#lblDui").text(p.DUI);
                    $("#lblFechaNac").text(formatearFecha(p.FechaNacimiento));
                    $("#lblSexo").text(formatearSexo(p.Sexo));
                    $("#lblEstado").html(p.Activo ? '<span class="badge bg-success">Activo</span>' : '<span class="badge bg-danger">Inactivo</span>');
                    $("#lblTelefono").text(p.Telefono || "No registrado");
                    $("#lblEmail").text(p.Email || "No registrado");
                    $("#lblDireccion").text(p.Direccion || "No registrada");
                    $("#lblTipoSangre").text(p.TipoSangre || "No registrado");
                    $("#lblFechaRegistro").text(formatearFechaHora(p.FechaRegistro));
                    $("#lblAlergias").text(p.Alergias || "Ninguna registrada");
                    $("#lblAntecedentes").text(p.AntecedentesMedicos || "Sin antecedentes");
                    $("#lblIdPaciente").text(p.PacienteID);
                    $("#modalDetalles").modal("show");
                }
            });
        }

        // FUNCION PARA ABRIR EL MODAL (CREAR/MODIFICAR)
        function abrirModal(paciente) {
            const $modal = $("#modalPaciente");
            $modal.find("input, select, textarea").prop("disabled", false);
            $("#txtActivo").removeClass("opacity-50");

            if (paciente == null) {
                $("#txtIdPaciente").val(0);
                $modal.find("input:not([type=hidden]), textarea").val("");
                $("#txtSexo, #txtTipoSangre").val("");
                $("#txtActivo")
                    .prop("checked", true)      
                    .prop("disabled", true)     
                    .addClass("opacity-50");   
            
            } else {
                $("#txtActivo").prop("disabled", false);

                $("#txtIdPaciente").val(paciente.PacienteID);
                $("#txtNombre").val(paciente.Nombres);
                $("#txtApellido").val(paciente.Apellidos);
                $("#txtDui").val(paciente.DUI);
                $("#txtFechaNac").val(formatearFechaInput(paciente.FechaNacimiento));
                $("#txtSexo").val(paciente.Sexo);
                $("#txtTelefono").val(paciente.Telefono);
                $("#txtEmail").val(paciente.Email);
                $("#txtDireccion").val(paciente.Direccion);
                $("#txtTipoSangre").val(paciente.TipoSangre);
                $("#txtAlergias").val(paciente.Alergias);
                $("#txtAntecedentes").val(paciente.AntecedentesMedicos);
                $("#txtActivo").prop("checked", paciente.Activo);

                if (!paciente.Activo) {
                    $modal.find(".modal-body input:not(#txtActivo), .modal-body select, .modal-body textarea")
                        .prop("disabled", true);
                }
            }
            $modal.modal('show');
        }

        // FUNCION PARA GUARDAR (CREAR/MODIFICAR)
        function guardar() {
            //  FORMATEAR ANTES DE ENVIAR
            var telefono = formatearTelefono($("#txtTelefono").val());
            var dui = formatearDui($("#txtDui").val());

            //  VALIDACIÓN TELÉFONO
            if (telefono.length !== 9) {
                Swal.fire({
                    icon: 'error',
                    title: 'Teléfono inválido',
                    text: 'Debe tener formato 1111-1111'
                });
                return;
            }

            //DUI
            if (dui.length !== 10) {
                Swal.fire({
                    icon: 'error',
                    title: 'DUI inválido',
                    text: 'Debe tener formato 00000000-0'
                });
                return;
            }

            var request = {
                PacienteID: $("#txtIdPaciente").val(),
                Nombres: $("#txtNombre").val(),
                Apellidos: $("#txtApellido").val(),
                DUI: $("#txtDui").val(),
                FechaNacimiento: $("#txtFechaNac").val(),
                Sexo: $("#txtSexo").val(),
                Telefono: telefono,
                Email: $("#txtEmail").val(),
                Direccion: $("#txtDireccion").val(),
                TipoSangre: $("#txtTipoSangre").val(),
                Alergias: $("#txtAlergias").val(),
                AntecedentesMedicos: $("#txtAntecedentes").val(),
                Activo: $("#txtActivo").is(":checked")
            };

            $.ajax({
                url: UrlGuardar,
                type: "POST",
                data: JSON.stringify(request),
                contentType: "application/json; charset=utf-8",
                success: function (response) {

                    if (response.success) {

                        Swal.fire({
                            icon: 'success',
                            title: 'Guardado',
                            text: 'El paciente se guardó correctamente',
                            confirmButtonText: 'OK'
                        }).then(() => {
                            $('#modalPaciente').modal('hide');
                            vistaActual === "HISTORIAL" ? cargarDatosHistorial() : cargarDatos();
                        });

                    } else {

                        Swal.fire({
                            icon: 'error',
                            title: 'Error',
                            text: response.mensaje,
                            confirmButtonText: 'Entendido'
                        });

                    }
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error inesperado',
                        text: 'No se pudo completar la operación'
                    });
                }
            });
        }

        //FUNCIÓN PARA OBTENER DATOS DE PACIENTE A ELIMINAR
        function eliminar(id) {
            $.get(UrlConsultar, { id: id }, function (response) {
                if (response.success) {
                    var p = response.data;
                    $("#EliminarNombre").text(p.Nombres + " " + p.Apellidos);
                    $("#EliminarDui").text(p.DUI);
                    $("#EliminarId").text(p.PacienteID);
                    $("#hiddenIdEliminar").val(p.PacienteID);
                    $("#modalEliminar").modal("show");
                }
            });
        }

        //FUNCIÓN PARA ELIMINAR/DESACTIVAR PACIENTE (Eliminar lógico)
        function confirmarEliminar() {
            var id = $("#hiddenIdEliminar").val();
            $.post(UrlEliminar, { id: id }, function (response) {
                $("#modalEliminar").modal("hide");
                if (response.success) cargarDatos();
                else alert("Error: " + response.mensaje);
            });
        }
    </script>
}
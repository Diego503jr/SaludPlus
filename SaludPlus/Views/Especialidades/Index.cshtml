@{
    ViewBag.Title = "Gestión de Especialidades";
}

<link href="@Url.Content("~/Content/styles/Admin.css")" rel="stylesheet" />

@* Tabla principal *@
<div class="container-fluid mt-4 px-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white border-bottom py-3 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <h5 class="fw-bold mb-0 text-dark text-center text-md-start">Gestión de Especialidades</h5>
            <div class="d-flex gap-2 justify-content-center">
                <button class="btn btn-primary btn-sm px-3" onclick="abrirModal(null)">
                    <i class="bi bi-plus-circle-fill me-1"></i> Agregar Especialidad
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-nowrap mb-0" id="tablaEspecialidades">
                <thead class="table-light">
                    <tr>
                        <th class="text-muted">Nombre</th>
                        <th class="text-muted">Estado</th>
                        <th class="text-muted pe-4 text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modal Agregar / Editar Especialidad *@
<div class="modal fade" id="modalEspecialidad" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="modal-header bg-dark text-white border-0 py-3 px-4">
                <h6 class="modal-title d-flex align-items-center fw-bold">
                    <i class="bi bi-stethoscope me-2 fs-5"></i>
                    GESTIÓN DE ESPECIALIDAD
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-0">
                @Html.Hidden("txtIdEspecialidad", "0")

                <div class="container-fluid py-4 px-4 bg-light-subtle">
                    <div class="row g-3">

                        @* Nombre *@
                        <div class="col-12">
                            <div class="form-floating shadow-sm">
                                @Html.TextBox("txtNombre", null, new { @class = "form-control border-0 px-3", placeholder = "Nombre de la especialidad" })
                                <label class="small text-muted"><i class="bi bi-stethoscope me-1"></i>Nombre de la Especialidad</label>
                            </div>
                        </div>

                        @* Estado *@
                        <div class="col-12">
                            <div class="card shadow-sm border-0 d-flex flex-row align-items-center justify-content-start bg-white px-4 py-3 gap-3">
                                <div class="form-check form-switch p-0 m-0 d-flex align-items-center gap-3">
                                    <input class="form-check-input ms-0" type="checkbox" role="switch" id="chkActivo" checked
                                           style="width: 2.5em; height: 1.25em; cursor: pointer;">
                                    <label class="form-check-label small fw-bold text-success" for="chkActivo" id="lblEstadoTexto">ACTIVA</label>
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
            </div>

            <div class="modal-footer bg-white border-0 py-3 px-4">
                <button type="button" class="btn btn-link text-muted text-decoration-none fw-semibold" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-primary rounded-pill px-4 shadow-sm fw-bold" onclick="guardar()">
                    Guardar
                </button>
            </div>
        </div>
    </div>
</div>

@* Modal Detalles de Especialidad *@
<div class="modal fade" id="modalDetallesEspecialidad" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="modal-header bg-dark text-white py-3 px-4 border-0">
                <h6 class="modal-title fw-bold text-uppercase mb-0">
                    <i class="bi bi-stethoscope me-2"></i>Detalle de Especialidad
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <div class="d-flex align-items-center gap-3 mb-4">
                    <div class="rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center" style="width:56px;height:56px;min-width:56px;">
                        <i class="bi bi-stethoscope text-primary fs-3"></i>
                    </div>
                    <div>
                        <h4 class="fw-bold mb-0 text-dark" id="lblNombreDetalle"></h4>
                        <span class="text-muted small">ID: <span id="lblIdDetalle"></span></span>
                    </div>
                </div>

                <div class="card border-0 bg-light shadow-sm">
                    <div class="card-body p-3">
                        <p class="small fw-bold text-uppercase mb-3 border-bottom pb-1">Estado de la Especialidad</p>
                        <div id="statusEspecialidad"></div>
                    </div>
                </div>
            </div>

            <div class="modal-footer bg-white border-0 py-3">
                <button type="button" class="btn btn-outline-secondary rounded-pill px-4" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

@* Modal Confirmar Baja *@
<div class="modal fade" id="modalEliminar" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg rounded-4 overflow-hidden">

            <div class="modal-header bg-danger text-white py-3 px-4 border-0">
                <h6 class="modal-title fw-bold small text-uppercase mb-0">
                    <i class="bi bi-exclamation-octagon me-2"></i>Confirmar Baja
                </h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4 text-center">
                <div class="mb-3">
                    <i class="bi bi-x-circle-fill text-danger" style="font-size: 4rem; opacity: 0.8;"></i>
                </div>

                <h5 class="fw-bold text-dark">¿Desactivar esta especialidad?</h5>
                <p class="text-muted small px-3">Los médicos asociados podrían verse afectados.</p>

                <div class="row g-0 border rounded-3 text-start mt-4 shadow-sm overflow-hidden">
                    <div class="col-3 bg-light border-end d-flex flex-column justify-content-center align-items-center p-2">
                        <small class="text-muted fw-bold text-uppercase" style="font-size: 0.65rem;">ID</small>
                        <span class="h5 fw-bold text-danger mb-0" id="EliminarId"></span>
                    </div>
                    <div class="col-9 p-3 bg-white">
                        <small class="text-muted fw-bold text-uppercase d-block" style="font-size: 0.65rem;">Especialidad</small>
                        <h6 class="fw-bold mb-0" id="EliminarNombre"></h6>
                    </div>
                </div>

                <input type="hidden" id="hiddenIdEliminar" />
            </div>

            <div class="modal-footer bg-light py-3 border-top-0 d-flex justify-content-between px-4">
                <button type="button" class="btn btn-link text-muted text-decoration-none fw-bold small" data-bs-dismiss="modal">
                    CANCELAR
                </button>
                <button type="button" class="btn btn-danger rounded-pill px-4 fw-bold shadow-sm" onclick="confirmarEliminar()">
                    <i class="bi bi-trash3 me-1"></i> Confirmar Baja
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            cargarDatos();
        });

        document.getElementById('chkActivo').addEventListener('change', function () {
            const lbl = document.getElementById('lblEstadoTexto');
            if (this.checked) {
                lbl.innerText = "ACTIVA";
                lbl.className = "form-check-label small fw-bold text-success";
            } else {
                lbl.innerText = "INACTIVA";
                lbl.className = "form-check-label small fw-bold text-danger";
            }
        });

        // CARGAR TABLA
        function cargarDatos() {
            $.ajax({
                url: '@Url.Action("Listar", "Especialidades")',
                type: "GET",
                dataType: "json",
                success: function (data) {
                    var html = "";
                    if (!data || data.length === 0) {
                        html = "<tr><td colspan='4' class='text-center py-4 text-muted'>No hay registros</td></tr>";
                    } else {
                        $.each(data, function (i, item) {
                            let badgeColor = item.Activo ? "bg-success" : "bg-danger";
                            let estadoTexto = item.Activo ? "Activa" : "Inactiva";
                            let itemString = JSON.stringify(item).replace(/"/g, '&quot;');

                            html += "<tr>" +
                                "<td>" +
                                    "<div class='d-flex align-items-center gap-2'>" +
                                        "<div class='rounded-circle bg-primary bg-opacity-10 d-flex align-items-center justify-content-center' style='width:36px;height:36px;min-width:36px;'>" +
                                            "<i class='bi bi-stethoscope text-primary' style='font-size:1rem;'></i>" +
                                        "</div>" +
                                        "<span class='fw-bold text-dark'>" + item.Nombre + "</span>" +
                                    "</div>" +
                                "</td>" +
                                "<td>" +
                                    "<span class='badge " + badgeColor + " py-2 fw-bold d-inline-block text-center' style='font-size:0.75rem;width:80px;'>" + estadoTexto + "</span>" +
                                "</td>" +
                                "<td class='pe-4 text-center'>" +
                                    "<div class='btn-group shadow-sm'>" +
                                        "<button class='btn btn-light btn-sm border-end text-primary' onclick='abrirModal(" + itemString + ")'><i class='bi bi-pencil'></i></button>" +
                                        "<button class='btn btn-light btn-sm border-end text-secondary' onclick='consultarDetalles(" + item.EspecialidadID + ")'><i class='bi bi-eye'></i></button>" +
                                        "<button class='btn btn-light btn-sm text-danger' onclick='eliminar(" + item.EspecialidadID + ")'><i class='bi bi-x-circle'></i></button>" +
                                    "</div>" +
                                "</td>" +
                            "</tr>";
                        });
                    }
                    $("#tablaEspecialidades tbody").html(html);
                }
            });
        }

        // ABRIR MODAL (AGREGAR / EDITAR)
        function abrirModal(espe) {
            const lblEstado = $("#lblEstadoTexto");

            if (espe == null) {
                $("#txtIdEspecialidad").val(0);
                $("#txtNombre").val("");
                $("#chkActivo").prop("checked", true);
                lblEstado.text("ACTIVA").removeClass("text-danger").addClass("text-success");
            } else {
                $("#txtIdEspecialidad").val(espe.EspecialidadID);
                $("#txtNombre").val(espe.Nombre);
                $("#chkActivo").prop("checked", espe.Activo);
                if (espe.Activo) {
                    lblEstado.text("ACTIVA").removeClass("text-danger").addClass("text-success");
                } else {
                    lblEstado.text("INACTIVA").removeClass("text-success").addClass("text-danger");
                }
            }

            $('#modalEspecialidad').modal('show');
        }

        // GUARDAR
        function guardar() {
            var request = {
                EspecialidadID: parseInt($("#txtIdEspecialidad").val()),
                Nombre: $("#txtNombre").val(),
                Activo: $("#chkActivo").prop("checked")
            };

            $.ajax({
                url: '@Url.Action("Guardar", "Especialidades")',
                type: "POST",
                data: JSON.stringify(request),
                contentType: "application/json; charset=utf-8",
                success: function (response) {
                    if (response.success) {
                        $('#modalEspecialidad').modal('hide');
                        cargarDatos();
                    } else {
                        alert(response.message || response.mensaje);
                    }
                }
            });
        }

        // PREPARAR MODAL ELIMINAR
        function eliminar(id) {
            $.get('@Url.Action("Consultar", "Especialidades")', { id: id }, function (response) {
                if (response.success) {
                    var e = response.data;
                    $("#EliminarId").text(e.EspecialidadID);
                    $("#EliminarNombre").text(e.Nombre);
                    $("#hiddenIdEliminar").val(e.EspecialidadID);
                    $("#modalEliminar").modal("show");
                }
            });
        }

        // CONFIRMAR BAJA
        function confirmarEliminar() {
            var id = $("#hiddenIdEliminar").val();
            $.post('@Url.Action("Eliminar", "Especialidades")', { id: id }, function (response) {
                if (response.success) {
                    $("#modalEliminar").modal("hide");
                    cargarDatos();
                } else {
                    alert(response.mensaje);
                }
            });
        }

        // VER DETALLES
        function consultarDetalles(id) {
            $.get('@Url.Action("Consultar", "Especialidades")', { id: id }, function (response) {
                if (response.success) {
                    var e = response.data;
                    $("#lblNombreDetalle").text(e.Nombre);
                    $("#lblIdDetalle").text(e.EspecialidadID);

                    let statusHtml = e.Activo
                        ? '<span class="badge bg-success fs-6 w-100 py-2">ACTIVA</span>'
                        : '<span class="badge bg-danger fs-6 w-100 py-2">INACTIVA</span>';
                    $("#statusEspecialidad").html(statusHtml);

                    $("#modalDetallesEspecialidad").modal("show");
                }
            });
        }
    </script>
}
@{
    ViewBag.Title = "Catálogo de Farmacia";
}

<div class="container-fluid mt-4 px-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0 text-dark"><i class="fas fa-pills text-success me-2"></i>Gestión de Medicamentos</h5>
            <button class="btn btn-success btn-sm px-3 shadow-sm" onclick="abrirModal(null)">
                <i class="fas fa-plus me-1"></i> Nuevo Medicamento
            </button>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-hover mb-0" id="tablaMedicamentos">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Nombre Comercial</th>
                        <th>Laboratorio</th>
                        <th>Presentación</th>
                        <th>Stock Actual</th>
                        <th>Precio ($)</th>
                        <th class="text-center">Acciones</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="modalMedicamento" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header bg-success text-white">
                <h6 class="modal-title fw-bold" id="tituloModal"><i class="fas fa-capsules me-2"></i>Detalle de Medicamento</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="txtId" value="0" />
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Nombre del Medicamento <span class="text-danger">*</span></label>
                        <input type="text" id="txtNombre" class="form-control" placeholder="Ej. Acetaminofén 500mg" />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Laboratorio</label>
                        <input type="text" id="txtLaboratorio" class="form-control" placeholder="Ej. MK, Bayer..." />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Presentación</label>
                        <select id="cboPresentacion" class="form-select">
                            <option value="Tabletas">Tabletas</option>
                            <option value="Cápsulas">Cápsulas</option>
                            <option value="Jarabe">Jarabe</option>
                            <option value="Inyección">Inyección</option>
                            <option value="Crema/Ungüento">Crema/Ungüento</option>
                            <option value="Gotas">Gotas</option>
                        </select>
                    </div>
                    <div class="col-md-6">
                        <label class="form-label fw-bold small">Vía de Administración</label>
                        <select id="cboVia" class="form-select">
                            <option value="Oral">Oral</option>
                            <option value="Intravenosa">Intravenosa</option>
                            <option value="Intramuscular">Intramuscular</option>
                            <option value="Tópica">Tópica</option>
                            <option value="Oftálmica">Oftálmica</option>
                        </select>
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">Stock Inicial</label>
                        <input type="number" id="txtStock" class="form-control" value="0" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">Stock Mínimo (Alerta)</label>
                        <input type="number" id="txtMinimo" class="form-control" value="10" min="0" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold small">Precio Unitario ($)</label>
                        <input type="number" id="txtPrecio" class="form-control" value="0.00" step="0.01" min="0" />
                    </div>
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success fw-bold" onclick="guardar()">Guardar Registro</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <!-- LIBRERÍA SWEETALERT2 -->
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            cargarMedicamentos();
        });

        // 1. CARGAR TABLA
        function cargarMedicamentos() {
            $.get('@Url.Action("Listar", "Medicamentos")', function (data) {
                let html = "";
                $.each(data, function (i, item) {

                    let presentacion = item.Presentacion ? item.Presentacion : "No definida";
                    let via = item.ViaAdministracion ? item.ViaAdministracion : "";
                    let esComodin = item.Nombre === "MEDICAMENTO EXTERNO (Solo texto)";

                    let filaClass = esComodin ? "table-primary fw-bold" : "";
                    let stockBadge = esComodin ? `<span class="badge bg-success">∞</span>` :
                                     (item.StockActual <= item.StockMinimo ? `<span class="badge bg-danger">${item.StockActual}</span>` : `<span class="badge bg-success">${item.StockActual}</span>`);

                    let acciones = "";
                    if (esComodin) {
                        acciones = `<span class="badge bg-primary"><i class="fas fa-lock me-1"></i> Sistema</span>`;
                    } else {
                        acciones = `
                            <button class="btn btn-sm btn-outline-primary shadow-sm me-1" onclick="editarMedicamento(${item.MedicamentoID})"><i class="fas fa-edit"></i></button>
                            <button class="btn btn-sm btn-outline-danger shadow-sm" onclick="eliminarMedicamento(${item.MedicamentoID})"><i class="fas fa-trash"></i></button>
                        `;
                    }


                    let precioFormateado = parseFloat(item.Precio || 0).toFixed(2);

                    html += `<tr class="${filaClass}">
                                <td class="fw-bold">${item.Nombre}</td>
                                <td class="text-muted">${item.Laboratorio || '-'}</td>
                                <td>${presentacion} <small class="text-muted">(${via})</small></td>
                                <td class="text-center">${stockBadge}</td>
                                <td class="fw-bold text-success">$${precioFormateado}</td>
                                <td class="text-center">${acciones}</td>
                             </tr>`;
                });
                $("#tablaMedicamentos tbody").html(html);
            });
        }

        // ABRIR MODAL PARA NUEVO MEDICAMENTO
        function abrirModal() {
            $("#txtId").val("0");
            $("#txtNombre").val("");
            $("#txtLaboratorio").val("");
            $("#cboPresentacion").val("Tabletas");
            $("#cboVia").val("Oral");
            $("#txtStock").val("0");
            $("#txtMinimo").val("10");
            $("#txtPrecio").val("0.00");

            $("#tituloModal").html('<i class="fas fa-capsules me-2"></i>Nuevo Medicamento');
            $("#modalMedicamento").modal('show');
        }

        // 3. EDITAR MEDICAMENTO
        function editarMedicamento(id) {
            $.get('/Medicamentos/Consultar?id=' + id, function (res) {
                if (res.success) {
                    let m = res.data;

                    $("#txtId").val(m.MedicamentoID);
                    $("#txtNombre").val(m.Nombre);
                    $("#txtLaboratorio").val(m.Laboratorio);
                    $("#txtStock").val(m.StockActual);
                    $("#txtMinimo").val(m.StockMinimo);

                    let precioLimpio = parseFloat(m.Precio || 0).toFixed(2);
                    $("#txtPrecio").val(precioLimpio);

                    // Forzar opción en el Select de Vía si no existe
                    if ($(`#cboVia option[value='${m.ViaAdministracion}']`).length === 0 && m.ViaAdministracion) {
                        $("#cboVia").append(`<option value="${m.ViaAdministracion}">${m.ViaAdministracion}</option>`);
                    }
                    $("#cboVia").val(m.ViaAdministracion);

                    // Forzar opción en el Select de Presentación si no existe
                    if ($(`#cboPresentacion option[value='${m.Presentacion}']`).length === 0 && m.Presentacion) {
                        $("#cboPresentacion").append(`<option value="${m.Presentacion}">${m.Presentacion}</option>`);
                    }
                    $("#cboPresentacion").val(m.Presentacion);

                    $("#tituloModal").html('<i class="fas fa-edit me-2"></i>Editar Medicamento');
                    $("#modalMedicamento").modal('show');
                } else {
                    Swal.fire('Error', res.mensaje, 'error');
                }
            });
        }

        // 4. GUARDAR REGISTRO
        function guardar() {
            let nombre = $("#txtNombre").val().trim();
            if (!nombre) {
                Swal.fire('Atención', 'El nombre del medicamento es obligatorio.', 'warning');
                return;
            }

            let obj = {
                MedicamentoID: $("#txtId").val(),
                Nombre: nombre,
                Laboratorio: $("#txtLaboratorio").val(),
                Presentacion: $("#cboPresentacion").val(),
                ViaAdministracion: $("#cboVia").val(),
                StockActual: $("#txtStock").val(),
                StockMinimo: $("#txtMinimo").val(),
                Precio: $("#txtPrecio").val()
            };

            $.post('/Medicamentos/Guardar', obj, function (res) {
                if (res.success) {
                    Swal.fire({
                        icon: 'success',
                        title: '¡Guardado!',
                        text: 'El medicamento se guardó correctamente.',
                        showConfirmButton: false,
                        timer: 1500
                    });
                    $("#modalMedicamento").modal('hide');
                    cargarMedicamentos();
                } else {
                    Swal.fire('Error', res.mensaje, 'error');
                }
            });
        }

        // 5. ELIMINAR CON SWEETALERT2
        function eliminarMedicamento(id) {
            Swal.fire({
                title: '¿Eliminar Medicamento?',
                text: "Esta acción no se puede deshacer.",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#dc3545',
                cancelButtonColor: '#6c757d',
                confirmButtonText: 'Sí, eliminar',
                cancelButtonText: 'Cancelar'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Medicamentos/Eliminar?id=' + id, function (res) {
                        if (res.success) {
                            Swal.fire('Eliminado!', 'El medicamento ha sido borrado.', 'success');
                            cargarMedicamentos();
                        } else {
                            Swal.fire('No se puede eliminar', res.mensaje, 'error');
                        }
                    });
                }
            });
        }
    </script>
}
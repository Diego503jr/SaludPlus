@{
    ViewBag.Title = "Panel de Consultas";
}

<link href="~/Content/styles/Admin.css" rel="stylesheet" />

<div class="container-fluid mt-4 px-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white border-bottom py-3 d-flex flex-column flex-md-row justify-content-between align-items-center gap-3">
            <h5 id="tituloVista" class="fw-bold mb-0 text-dark text-center text-md-start">
                <i class="fas fa-stethoscope text-primary me-2"></i>Historial de Consultas
            </h5>

            <div class="d-flex gap-2 justify-content-center">
                <button class="btn btn-primary btn-sm px-3 shadow-sm" onclick="abrirModal(null)">
                    <i class="fas fa-notes-medical me-1"></i> Iniciar Consulta
                </button>
                <button class="btn btn-outline-secondary btn-sm px-3" onclick="cargarDatos()">
                    <i class="fas fa-sync-alt me-1"></i> Actualizar
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-nowrap mb-0" id="tablaConsultas">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4 text-muted" style="width: 120px;">Fecha</th>
                        <th class="text-muted">Paciente</th>
                        <th class="text-muted">Médico</th>
                        <th class="text-muted">Motivo</th>
                        <th class="text-muted">Diagnóstico</th>
                        <th class="text-muted pe-4 text-center">Expediente</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

@* Modal Gigante con Pestañas para la Consulta *@
<div class="modal fade shadow-lg" id="modalConsulta" tabindex="-1" data-bs-backdrop="static" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header bg-primary text-white py-3 px-4 rounded-top-4">
                <h5 class="modal-title fw-bold">
                    <i class="fas fa-clipboard-list me-2"></i>Ficha de Consulta Médica
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>

            <div class="modal-body p-0 bg-light-subtle">
                <input type="hidden" id="txtIdConsulta" value="0" />

                <div class="p-3 bg-white border-bottom d-flex align-items-center gap-3">
                    <label class="fw-bold text-muted mb-0" style="white-space: nowrap;">Atendiendo a:</label>
                    <select id="cboCitaPendiente" class="form-select form-select-lg border-primary shadow-sm" style="font-weight: 500;">
                        <option value="">-- Seleccione un paciente en sala de espera --</option>
                    </select>
                </div>

                <ul class="nav nav-tabs nav-fill bg-white border-bottom-0 pt-2 px-3" id="consultaTabs" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active fw-bold" id="signos-tab" data-bs-toggle="tab" data-bs-target="#signos" type="button" role="tab">
                            <i class="fas fa-heartbeat me-1"></i> Signos Vitales
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold" id="evaluacion-tab" data-bs-toggle="tab" data-bs-target="#evaluacion" type="button" role="tab">
                            <i class="fas fa-user-md me-1"></i> Evaluación
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link fw-bold" id="tratamiento-tab" data-bs-toggle="tab" data-bs-target="#tratamiento" type="button" role="tab">
                            <i class="fas fa-pills me-1"></i> Tratamiento
                        </button>
                    </li>
                </ul>

                <div class="tab-content p-4" id="consultaTabsContent">

                    <div class="tab-pane fade show active" id="signos" role="tabpanel">
                        <div class="row g-4">
                            <div class="col-md-3">
                                <label class="form-label small fw-semibold">Peso (kg)</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white"><i class="fas fa-weight"></i></span>
                                    <input type="number" step="0.1" id="txtPeso" class="form-control" placeholder="Ej. 70.5" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-semibold">Talla (cm)</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white"><i class="fas fa-ruler-vertical"></i></span>
                                    <input type="number" id="txtTalla" class="form-control" placeholder="Ej. 175" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-semibold">Presión Arterial</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white"><i class="fas fa-tint"></i></span>
                                    <input type="text" id="txtPresion" class="form-control" placeholder="120/80" />
                                </div>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label small fw-semibold">Temperatura (°C)</label>
                                <div class="input-group shadow-sm">
                                    <span class="input-group-text bg-white"><i class="fas fa-thermometer-half"></i></span>
                                    <input type="number" step="0.1" id="txtTemp" class="form-control" placeholder="37.0" />
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="evaluacion" role="tabpanel">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Motivo de la Consulta</label>
                                <textarea id="txtMotivo" class="form-control shadow-sm" rows="2" placeholder="¿Por qué viene el paciente hoy?"></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Examen Físico / Notas</label>
                                <textarea id="txtExamenFisico" class="form-control shadow-sm" rows="3" placeholder="Hallazgos durante la revisión médica..."></textarea>
                            </div>
                            <div class="col-12 border-top pt-3 mt-3">
                                <label class="form-label fw-bold text-primary">Diagnóstico Definitivo o Presuntivo</label>
                                <input type="text" id="txtDiagnostico" class="form-control form-control-lg shadow-sm border-primary" placeholder="Ej. Faringitis Aguda" />
                            </div>
                        </div>
                    </div>

                    <div class="tab-pane fade" id="tratamiento" role="tabpanel">
                        <div class="row g-3">
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Tratamiento Farmacológico (Receta interna)</label>
                                <textarea id="txtTratamiento" class="form-control shadow-sm" rows="3" placeholder="Medicamentos, dosis y frecuencia..."></textarea>
                            </div>
                            <div class="col-12">
                                <label class="form-label small fw-semibold">Indicaciones Generales (Dieta, reposo)</label>
                                <textarea id="txtIndicaciones" class="form-control shadow-sm" rows="2" placeholder="Reposo por 3 días, dieta blanda..."></textarea>
                            </div>
                            <div class="col-md-4 mt-3">
                                <label class="form-label small fw-semibold">Programar Próxima Revisión</label>
                                <input type="date" id="txtProximaRevision" class="form-control shadow-sm" />
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <div class="modal-footer bg-light border-0 py-3 rounded-bottom-4 justify-content-between">
                <span class="text-muted small"><i class="fas fa-info-circle"></i> Asegúrese de completar la evaluación antes de guardar.</span>
                <div>
                    <button type="button" class="btn btn-outline-secondary px-4 fw-bold shadow-sm" data-bs-dismiss="modal">Cancelar</button>
                    <button type="button" class="btn btn-success px-4 fw-bold shadow-sm" onclick="guardar()">
                        <i class="fas fa-save me-1"></i> Guardar Expediente
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            cargarDatos();
        });

        // Formateador de fechas
        function formatearFecha(fechaJson) {
            if (!fechaJson) return "";
            var milisegundos = parseInt(fechaJson.replace("/Date(", "").replace(")/", ""));
            var fecha = new Date(milisegundos);
            var dia = ("0" + fecha.getDate()).slice(-2);
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var anio = fecha.getFullYear();
            return dia + "/" + mes + "/" + anio;
        }

        function formatearFechaInput(fechaJson) {
            if (!fechaJson) return "";
            var milisegundos = parseInt(fechaJson.replace("/Date(", "").replace(")/", ""));
            var fecha = new Date(milisegundos);
            var dia = ("0" + fecha.getDate()).slice(-2);
            var mes = ("0" + (fecha.getMonth() + 1)).slice(-2);
            var anio = fecha.getFullYear();
            return anio + "-" + mes + "-" + dia;
        }

        // 1. CARGAR HISTORIAL DE CONSULTAS
        function cargarDatos() {
            $.ajax({
                url: '@Url.Action("Listar", "Consultas")',
                type: "GET",
                success: function (data) {
                    var html = "";
                    $.each(data, function (i, item) {
                        html += "<tr>" +
                            "<td class='ps-4 fw-bold text-dark'>" + formatearFecha(item.FechaConsulta) + "</td>" +
                            "<td><h6 class='mb-0 fw-bold' style='font-size: 0.9rem;'>" + item.PacienteNombre + "</h6></td>" +
                            "<td><span class='text-muted' style='font-size: 0.85rem;'><i class='fas fa-user-md'></i> Dr. " + item.MedicoNombre + "</span></td>" +
                            "<td><span class='text-muted text-truncate d-inline-block' style='max-width: 150px; font-size: 0.85rem;'>" + (item.MotivoConsulta || "---") + "</span></td>" +
                            "<td><span class='badge bg-info-subtle text-info-emphasis px-2 py-1'>" + (item.Diagnostico || "Pendiente") + "</span></td>" +
                            "<td class='pe-4 text-center'>" +
                                "<button class='btn btn-light btn-sm text-primary shadow-sm border' title='Ver/Editar Expediente' onclick='abrirModal(" + item.ConsultaID + ")'><i class='fas fa-folder-open'></i></button>" +
                            "</td>" +
                            "</tr>";
                    });
                    $("#tablaConsultas tbody").html(html);
                }
            });
        }

        // 2. CARGAR CITAS PENDIENTES EN LA SALA DE ESPERA
        function cargarCitasPendientes(citaSeleccionada = null) {
            $.get('@Url.Action("ObtenerCitasPendientes", "Consultas")', function (data) {
                let html = '<option value="">-- Seleccione un paciente en sala de espera --</option>';
                $.each(data, function (i, item) {
                    html += `<option value="${item.Id}">${item.Texto}</option>`;
                });
                $("#cboCitaPendiente").html(html);

                if(citaSeleccionada) {
                    // Si estamos editando, inyectamos una opción oculta con la cita original por si ya no está "Pendiente"
                    if($("#cboCitaPendiente option[value='"+citaSeleccionada+"']").length === 0) {
                        $("#cboCitaPendiente").append(`<option value="${citaSeleccionada}">Cita Histórica #${citaSeleccionada}</option>`);
                    }
                    $("#cboCitaPendiente").val(citaSeleccionada);
                    $("#cboCitaPendiente").prop("disabled", true); // No se puede cambiar de paciente una vez guardado
                } else {
                    $("#cboCitaPendiente").prop("disabled", false);
                }
            });
        }

        // 3. ABRIR EL MODAL (NUEVA CONSULTA O EDITAR)
        function abrirModal(idConsulta) {
            // Resetear pestañas al primer tab
            var firstTab = new bootstrap.Tab(document.querySelector('#signos-tab'));
            firstTab.show();

            if (idConsulta == null) {
                // MODO: NUEVA CONSULTA
                $("#txtIdConsulta").val(0);
                cargarCitasPendientes();

                // Limpiar campos
                $("#txtPeso").val(""); $("#txtTalla").val(""); $("#txtPresion").val(""); $("#txtTemp").val("");
                $("#txtMotivo").val(""); $("#txtExamenFisico").val(""); $("#txtDiagnostico").val("");
                $("#txtTratamiento").val(""); $("#txtIndicaciones").val(""); $("#txtProximaRevision").val("");

                $('#modalConsulta').modal('show');
            } else {
                // MODO: VER/EDITAR EXPEDIENTE EXISTENTE
                $.ajax({
                    url: "/Consultas/Consultar?id=" + idConsulta,
                    type: "GET",
                    success: function (response) {
                        if (response.success) {
                            var p = response.data;
                            $("#txtIdConsulta").val(p.ConsultaID);
                            cargarCitasPendientes(p.CitaID); // Carga y bloquea el select

                            $("#txtPeso").val(p.PesoKg);
                            $("#txtTalla").val(p.TallaCm);
                            $("#txtPresion").val(p.PresionArterial);
                            $("#txtTemp").val(p.Temperatura);

                            $("#txtMotivo").val(p.MotivoConsulta);
                            $("#txtExamenFisico").val(p.ExamenFisico);
                            $("#txtDiagnostico").val(p.Diagnostico);

                            $("#txtTratamiento").val(p.Tratamiento);
                            $("#txtIndicaciones").val(p.Indicaciones);
                            $("#txtProximaRevision").val(formatearFechaInput(p.ProximaRevision));

                            $('#modalConsulta').modal('show');
                        } else {
                            alert(response.mensaje);
                        }
                    }
                });
            }
        }

        // 4. GUARDAR EXPEDIENTE
        function guardar() {
            var idCita = $("#cboCitaPendiente").val();
            var idConsulta = $("#txtIdConsulta").val();

            if (idConsulta == "0" && !idCita) {
                alert("Debe seleccionar un paciente de la sala de espera para iniciar la consulta.");
                // Forzar visualización de la alerta resaltando el select
                $("#cboCitaPendiente").focus();
                return;
            }

            var request = {
                ConsultaID: idConsulta,
                CitaID: idCita, // Si es nuevo, agarra el ID de la cita para vincularlos

                PesoKg: parseFloat($("#txtPeso").val()) || null,
                TallaCm: parseFloat($("#txtTalla").val()) || null,
                PresionArterial: $("#txtPresion").val(),
                Temperatura: parseFloat($("#txtTemp").val()) || null,

                MotivoConsulta: $("#txtMotivo").val(),
                ExamenFisico: $("#txtExamenFisico").val(),
                Diagnostico: $("#txtDiagnostico").val(),

                Tratamiento: $("#txtTratamiento").val(),
                Indicaciones: $("#txtIndicaciones").val(),
                ProximaRevision: $("#txtProximaRevision").val() || null
            };

            $.ajax({
                url: '@Url.Action("Guardar", "Consultas")',
                type: "POST",
                data: JSON.stringify(request),
                contentType: "application/json; charset=utf-8",
                dataType: "json",
                success: function (response) {
                    if (response.success) {
                        $('#modalConsulta').modal('hide');
                        cargarDatos();
                    } else {
                        alert("Error al guardar: " + response.mensaje);
                    }
                }
            });
        }
    </script>
}
@{
    ViewBag.Title = "Panel de Consultas";
}

<div class="container-fluid mt-4 px-4">
    <div class="card shadow-sm border-0 rounded-3">
        <div class="card-header bg-white border-bottom py-3 d-flex justify-content-between align-items-center">
            <h5 class="fw-bold mb-0 text-dark"><i class="fas fa-stethoscope text-primary me-2"></i>Historial de Consultas</h5>
            <div>
                <button class="btn btn-primary btn-sm px-3 shadow-sm" onclick="abrirModalSeleccion()">
                    <i class="fas fa-user-check me-1"></i> Llamar Paciente
                </button>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table align-middle table-nowrap mb-0" id="tablaConsultas">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Fecha</th>
                        <th>Paciente</th>
                        <th>Médico</th>
                        <th>Diagnóstico</th>
                        <th class="text-center">Expediente</th>
                    </tr>
                </thead>
                <tbody>
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade shadow-lg" id="modalSeleccion" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 rounded-4">
            <div class="modal-header bg-primary text-white">
                <h6 class="modal-title fw-bold"><i class="fas fa-clipboard-list me-2"></i>Seleccionar Paciente</h6>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <label class="form-label fw-bold text-muted small">Pacientes en Sala de Espera:</label>
                <select id="cboCitaPendiente" class="form-select form-select-lg shadow-sm border-primary">
                    <option value="">-- Seleccione una cita --</option>
                </select>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Cancelar</button>
                <button type="button" class="btn btn-success fw-bold" onclick="iniciarConsultaFicha()">Proceder a Consulta <i class="fas fa-arrow-right ms-1"></i></button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            cargarDatos();
        });

        function formatearFecha(fechaJson) {
            if (!fechaJson) return "";
            var ms = parseInt(fechaJson.replace("/Date(", "").replace(")/", ""));
            var d = new Date(ms);
            return ("0" + d.getDate()).slice(-2) + "/" + ("0" + (d.getMonth() + 1)).slice(-2) + "/" + d.getFullYear();
        }

        function cargarDatos() {
            $.get('@Url.Action("Listar", "Consultas")', function (data) {
                var html = "";
                $.each(data, function (i, item) {
                    html += `<tr>
                        <td class='ps-4 fw-bold'>${formatearFecha(item.FechaConsulta)}</td>
                        <td><h6 class='mb-0 fw-bold'>${item.PacienteNombre}</h6></td>
                        <td><span class='text-muted'><i class='fas fa-user-md'></i> Dr. ${item.MedicoNombre}</span></td>
                        <td><span class='badge bg-info-subtle text-info-emphasis px-2 py-1'>${item.Diagnostico || "Pendiente"}</span></td>
                        <td class='text-center'>
                            <a href='/Consultas/Ficha?consultaId=${item.ConsultaID}' class='btn btn-light btn-sm text-primary shadow-sm border'>
                                <i class='fas fa-folder-open'></i> Abrir
                            </a>
                        </td>
                    </tr>`;
                });
                $("#tablaConsultas tbody").html(html);
            });
        }

        function abrirModalSeleccion() {
            $.get('@Url.Action("ObtenerCitasPendientes", "Consultas")', function (data) {
                let html = '<option value="">-- Seleccione una cita --</option>';
                $.each(data, function (i, item) { html += `<option value="${item.Id}">${item.Texto}</option>`; });
                $("#cboCitaPendiente").html(html);
                $('#modalSeleccion').modal('show');
            });
        }

        // EL REDIRECCIONAMIENTO
        function iniciarConsultaFicha() {
            var idCita = $("#cboCitaPendiente").val();
            if (!idCita) {
                alert("Por favor, seleccione un paciente de la lista.");
                return;
            }
            // Mandamos al médico a la pantalla completa pasando el ID de la cita en la URL
            window.location.href = '/Consultas/Ficha?citaId=' + idCita;
        }
    </script>
}
@{
    ViewBag.Title = "Ficha Clínica del Paciente";
}

<input type="hidden" id="hdnCitaID" value="@ViewBag.CitaID" />
<input type="hidden" id="hdnConsultaID" value="@ViewBag.ConsultaID" />

<div class="container-fluid mt-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold text-dark"><i class="fas fa-notes-medical text-primary me-2"></i> Expediente Médico</h4>
        <a href="@Url.Action("Index", "Consultas")" class="btn btn-outline-secondary"><i class="fas fa-arrow-left me-1"></i> Volver al Panel</a>
    </div>

    <div class="alert alert-primary border-0 shadow-sm d-flex align-items-center mb-4" role="alert" style="background-color: #e8f4fd;">
        <i class="fas fa-user-injured fs-2 text-primary me-3"></i>
        <div>
            <h5 class="mb-0 fw-bold text-dark">Atendiendo a: <span class="text-primary">@ViewBag.PacienteNombre</span></h5>
            <small class="text-muted"><i class="fas fa-exclamation-triangle text-warning me-1"></i>Verifique que el paciente en el consultorio coincida con este expediente.</small>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">

        <div class="card-header bg-white border-bottom-0 pt-4 pb-0 px-4">
            <ul class="nav nav-tabs nav-fill border-bottom-0" id="consultaTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold fs-6" id="evaluacion-tab" data-bs-toggle="tab" data-bs-target="#evaluacion" type="button" role="tab">
                        <i class="fas fa-user-md me-1"></i> Evaluación Clínica
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold fs-6" id="signos-tab" data-bs-toggle="tab" data-bs-target="#signos" type="button" role="tab">
                        <i class="fas fa-heartbeat me-1"></i> Signos Vitales
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold fs-6" id="tratamiento-tab" data-bs-toggle="tab" data-bs-target="#tratamiento" type="button" role="tab">
                        <i class="fas fa-pills me-1"></i> Receta y Tratamiento
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body bg-light-subtle p-4 rounded-bottom-4 border-top">
            <div class="tab-content" id="consultaTabsContent">

                <div class="tab-pane fade show active" id="evaluacion" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">Motivo de la Consulta <span class="text-danger">*</span></label>
                            <textarea id="txtMotivo" class="form-control form-control-lg shadow-sm" rows="2" placeholder="Describa los síntomas principales..."></textarea>
                            <small class="text-danger d-none error-msg" id="errMotivo">Este campo es obligatorio.</small>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Examen Físico</label>
                            <textarea id="txtExamenFisico" class="form-control shadow-sm" rows="4" placeholder="Hallazgos durante la revisión..."></textarea>
                        </div>
                        <div class="col-12 p-3 bg-white border border-primary border-opacity-25 rounded-3">
                            <label class="form-label fw-bold text-primary fs-5">Diagnóstico Definitivo <span class="text-danger">*</span></label>
                            <input type="text" id="txtDiagnostico" class="form-control form-control-lg shadow-sm" placeholder="Ej. Amigdalitis Aguda" />
                            <small class="text-danger d-none error-msg" id="errDiagnostico">Debe ingresar un diagnóstico válido.</small>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="signos" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Peso (kg)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white"><i class="fas fa-weight"></i></span>
                                <input type="number" step="0.1" id="txtPeso" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Talla (cm)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white"><i class="fas fa-ruler-vertical"></i></span>
                                <input type="number" id="txtTalla" class="form-control" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Presión Arterial</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white"><i class="fas fa-tint"></i></span>
                                <input type="text" id="txtPresion" class="form-control" placeholder="120/80" />
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold">Temp. (°C)</label>
                            <div class="input-group shadow-sm">
                                <span class="input-group-text bg-white"><i class="fas fa-thermometer-half"></i></span>
                                <input type="number" step="0.1" id="txtTemp" class="form-control" />
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tratamiento" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold">Tratamiento Farmacológico <span class="text-danger">*</span></label>
                            <textarea id="txtTratamiento" class="form-control shadow-sm" rows="3" placeholder="Medicamentos a recetar..."></textarea>
                            <small class="text-danger d-none error-msg" id="errTratamiento">Debe indicar el tratamiento.</small>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold">Indicaciones Generales</label>
                            <textarea id="txtIndicaciones" class="form-control shadow-sm" rows="2" placeholder="Reposo, dieta..."></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold">Próxima Revisión</label>
                            <input type="date" id="txtProximaRevision" class="form-control shadow-sm" />
                        </div>
                    </div>
                </div>

            </div>

            <hr class="my-4" />
            <div class="d-flex justify-content-end gap-2">
                <button type="button" class="btn btn-lg btn-success fw-bold shadow" onclick="guardarFicha()">
                    <i class="fas fa-save me-2"></i> Guardar y Finalizar Consulta
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Si estamos editando (ConsultaID > 0), cargamos los datos
            var consultaId = $("#hdnConsultaID").val();
            if (consultaId > 0) {
                cargarConsultaExistente(consultaId);
            }
        });

        // Ocultar mensajes de error cuando el usuario empieza a escribir
        $("input, textarea").on("input", function() {
            $(this).removeClass("is-invalid");
            $(this).siblings(".error-msg").addClass("d-none");
        });

        function cargarConsultaExistente(id) {
            $.get("/Consultas/Consultar?id=" + id, function (res) {
                if(res.success) {
                    let p = res.data;
                    $("#txtPeso").val(p.PesoKg); $("#txtTalla").val(p.TallaCm);
                    $("#txtPresion").val(p.PresionArterial); $("#txtTemp").val(p.Temperatura);
                    $("#txtMotivo").val(p.MotivoConsulta); $("#txtExamenFisico").val(p.ExamenFisico);
                    $("#txtDiagnostico").val(p.Diagnostico); $("#txtTratamiento").val(p.Tratamiento);
                    $("#txtIndicaciones").val(p.Indicaciones);
                    if(p.ProximaRevision) {
                        var ms = parseInt(p.ProximaRevision.replace("/Date(", "").replace(")/", ""));
                        var d = new Date(ms);
                        $("#txtProximaRevision").val(d.toISOString().split('T')[0]);
                    }
                }
            });
        }

        function guardarFicha() {
            // 1. VALIDACIONES
            let esValido = true;

            if(!$("#txtMotivo").val().trim()) {
                $("#txtMotivo").addClass("is-invalid");
                $("#errMotivo").removeClass("d-none");
                esValido = false;
            }
            if(!$("#txtDiagnostico").val().trim()) {
                $("#txtDiagnostico").addClass("is-invalid");
                $("#errDiagnostico").removeClass("d-none");
                esValido = false;
            }
            if(!$("#txtTratamiento").val().trim()) {
                $("#txtTratamiento").addClass("is-invalid");
                $("#errTratamiento").removeClass("d-none");
                esValido = false;
            }

            if(!esValido) {
                alert("Por favor, complete los campos obligatorios marcados en rojo.");
                // Te mueve a la primera pestaña automáticamente si hay error
                var firstTab = new bootstrap.Tab(document.querySelector('#evaluacion-tab'));
                firstTab.show();
                return;
            }

            // 2. CONSTRUIR OBJETO Y GUARDAR
            var request = {
                ConsultaID: $("#hdnConsultaID").val(),
                CitaID: $("#hdnCitaID").val(),
                PesoKg: parseFloat($("#txtPeso").val()) || null,
                TallaCm: parseFloat($("#txtTalla").val()) || null,
                PresionArterial: $("#txtPresion").val(),
                Temperatura: parseFloat($("#txtTemp").val()) || null,
                MotivoConsulta: $("#txtMotivo").val(),
                ExamenFisico: $("#txtExamenFisico").val(),
                Diagnostico: $("#txtDiagnostico").val(),
                Tratamiento: $("#txtTratamiento").val(),
                Indicaciones: $("#txtIndicaciones").val(),
                ProximaRevision: $("#txtProximaRevision").val() || null
            };

            $.ajax({
                url: '@Url.Action("Guardar", "Consultas")',
                type: "POST",
                data: JSON.stringify(request),
                contentType: "application/json; charset=utf-8",
                success: function (response) {
                    if (response.success) {
                        // ¡Si guarda con éxito, lo regresamos al Index!
                        window.location.href = '/Consultas/Index';
                    } else {
                        alert("Error de BD: " + response.mensaje);
                    }
                }
            });
        }
    </script>
}
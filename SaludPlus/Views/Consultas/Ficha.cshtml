@{
    ViewBag.Title = "Ficha Clínica";
}

<div class="container-fluid mt-4 px-4 mb-5">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="fw-bold text-dark mb-0"><i class="fas fa-notes-medical text-primary me-2"></i>Expediente Médico</h4>
        <a href="@Url.Action("Index", "Consultas")" class="btn btn-outline-secondary btn-sm shadow-sm">
            <i class="fas fa-arrow-left me-1"></i> Volver al Panel
        </a>
    </div>

    <div class="alert border-primary bg-primary-subtle d-flex align-items-center rounded-3 shadow-sm mb-4">
        <i class="fas fa-user-injured fs-3 text-primary me-3"></i>
        <div>
            <h6 class="mb-0 fw-bold text-primary">Atendiendo a: @ViewBag.PacienteNombre</h6>
            <small class="text-primary-emphasis"><i class="fas fa-exclamation-triangle text-warning me-1"></i>Verifique que el paciente en el consultorio coincida con este expediente.</small>
        </div>
    </div>

    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">

            <input type="hidden" id="hdnConsultaID" value="@ViewBag.ConsultaID" />
            <input type="hidden" id="hdnCitaID" value="@ViewBag.CitaID" />

            <ul class="nav nav-tabs nav-justified border-bottom-0 bg-light rounded-top-4 pt-2 px-2" id="fichaTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold" id="evaluacion-tab" data-bs-toggle="tab" data-bs-target="#evaluacion" type="button" role="tab">
                        <i class="fas fa-user-md me-1"></i> Evaluación Clínica
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold" id="signos-tab" data-bs-toggle="tab" data-bs-target="#signos" type="button" role="tab">
                        <i class="fas fa-heartbeat me-1"></i> Signos Vitales
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold text-success" id="tratamiento-tab" data-bs-toggle="tab" data-bs-target="#tratamiento" type="button" role="tab">
                        <i class="fas fa-pills me-1"></i> Receta y Tratamiento
                    </button>
                </li>
            </ul>

            <div class="tab-content p-4" id="fichaTabsContent">

                <div class="tab-pane fade show active" id="evaluacion" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-12">
                            <label class="form-label fw-bold small">Motivo de la Consulta <span class="text-danger">*</span></label>
                            <textarea id="txtMotivo" class="form-control" rows="2" placeholder="Describa el motivo principal..."></textarea>
                            <div class="invalid-feedback d-none" id="errMotivo">Este campo es obligatorio.</div>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small">Examen Físico</label>
                            <textarea id="txtExamenFisico" class="form-control" rows="3" placeholder="Hallazgos físicos..."></textarea>
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small">Diagnóstico Médico <span class="text-danger">*</span></label>
                            <textarea id="txtDiagnostico" class="form-control" rows="2" placeholder="Diagnóstico presuntivo o definitivo..."></textarea>
                            <div class="invalid-feedback d-none" id="errDiagnostico">El diagnóstico es obligatorio.</div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="signos" role="tabpanel">
                    <div class="row g-4">
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">Peso (Kg)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fas fa-weight"></i></span>
                                <input type="number" id="txtPeso" class="form-control" step="0.1" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">Talla (cm)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fas fa-ruler-vertical"></i></span>
                                <input type="number" id="txtTalla" class="form-control" step="1" min="0">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">Presión Arterial</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fas fa-tint"></i></span>
                                <input type="text" id="txtPresion" class="form-control" placeholder="Ej. 120/80">
                            </div>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small">Temperatura (°C)</label>
                            <div class="input-group">
                                <span class="input-group-text bg-white"><i class="fas fa-thermometer-half"></i></span>
                                <input type="number" id="txtTemp" class="form-control" step="0.1" min="30" max="45">
                            </div>
                        </div>
                    </div>
                </div>

                <div class="tab-pane fade" id="tratamiento" role="tabpanel">

                    <h6 class="fw-bold text-success mb-3"><i class="fas fa-prescription-bottle-alt me-2"></i>Emitir Receta Médica</h6>

                    <div class="row g-3 bg-success-subtle p-3 rounded-3 border border-success-subtle mb-4">
                        <div class="col-md-6">
                            <label class="form-label fw-bold small text-dark">Buscar Medicamento</label>
                            <select id="cboMedicamento" class="form-select shadow-sm border-success">
                                <option value="">Cargando catálogo...</option>
                            </select>
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small text-dark">Dosis</label>
                            <input type="text" id="txtDosis" class="form-control shadow-sm" placeholder="Ej. 1 tableta" />
                        </div>
                        <div class="col-md-3">
                            <label class="form-label fw-bold small text-dark">Cantidad a Despachar</label>
                            <input type="number" id="txtCantidad" class="form-control shadow-sm" value="1" min="1" />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-bold small text-dark">Indicaciones (Para imprimir en receta)</label>
                            <div class="input-group shadow-sm">
                                <input type="text" id="txtIndicaciones" class="form-control border-success" placeholder="Ej. Cada 8 horas por 5 días..." />
                                <button class="btn btn-success fw-bold" type="button" onclick="agregarMedicamento()">
                                    <i class="fas fa-plus me-1"></i> Agregar a Receta
                                </button>
                            </div>
                        </div>
                    </div>

                    <div class="table-responsive mb-4">
                        <table class="table table-sm table-bordered align-middle" id="tablaReceta">
                            <thead class="table-light">
                                <tr>
                                    <th>Medicamento</th>
                                    <th>Dosis</th>
                                    <th>Cantidad</th>
                                    <th>Indicaciones</th>
                                    <th class="text-center" style="width: 50px;">Acción</th>
                                </tr>
                            </thead>
                            <tbody>
                                <tr id="filaVacia"><td colspan="5" class="text-center text-muted py-3">No ha agregado medicamentos a la receta.</td></tr>
                            </tbody>
                        </table>
                    </div>

                    <hr />

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-bold small">Indicaciones Generales / Reposo</label>
                            <textarea id="txtIndicacionesGenerales" class="form-control" rows="2" placeholder="Dieta, reposo, cuidados..."></textarea>
                        </div>
                        <div class="col-md-4">
                            <label class="form-label fw-bold small">Próxima Revisión</label>
                            <input type="date" id="txtProximaRevision" class="form-control">
                        </div>
                    </div>

                </div>
            </div>

            <div class="card-footer bg-white border-top p-4 text-end">
                <button type="button" class="btn btn-success fw-bold px-4 shadow-sm" onclick="guardarFicha()">
                    <i class="fas fa-save me-2"></i>Guardar y Finalizar Consulta
                </button>
            </div>

        </div>
    </div>
</div>

@section Scripts {
    <script>
        var listaReceta = []; // Memoria temporal de la receta

        $(document).ready(function () {
            cargarCatalogoMedicamentos();
        });

        // 1. Cargar el Select con AJAX
        function cargarCatalogoMedicamentos() {
            $.get('@Url.Action("Listar", "Medicamentos")', function (data) {
                let html = '<option value="">-- Seleccione (Use "Medicamento Externo" si no está) --</option>';
                $.each(data, function (i, item) {
                    html += `<option value="${item.MedicamentoID}" data-stock="${item.StockActual}" data-nombre="${item.Nombre}">${item.Nombre}</option>`;
                });
                $("#cboMedicamento").html(html);
            });
        }

        // 2. Lógica del "Carrito"
        function agregarMedicamento() {
            let medId = $("#cboMedicamento").val();
            let nombre = $("#cboMedicamento option:selected").data("nombre");
            let stockDisponible = $("#cboMedicamento option:selected").data("stock");
            let dosis = $("#txtDosis").val();
            let cantidad = parseInt($("#txtCantidad").val());
            let indicaciones = $("#txtIndicaciones").val();

            if (!medId || cantidad < 1 || indicaciones.trim() === "") {
                alert("Por favor seleccione un medicamento, defina la cantidad y escriba las indicaciones.");
                return;
            }

            // Validar Stock
            if (cantidad > stockDisponible && nombre !== "MEDICAMENTO EXTERNO (Solo texto)") {
                alert("¡Stock insuficiente! Solo hay " + stockDisponible + " unidades disponibles.");
                return;
            }

            // Forzar nombre si es externo
            if (nombre === "MEDICAMENTO EXTERNO (Solo texto)" && !indicaciones.toLowerCase().includes("tomar")) {
                let conf = confirm("Seleccionó 'Medicamento Externo'. ¿Asegúrese de haber escrito el nombre de la medicina dentro de las indicaciones?");
                if(!conf) return;
            }

            let item = { MedicamentoID: parseInt(medId), Nombre: nombre, Dosis: dosis, Cantidad: cantidad, Indicaciones: indicaciones };
            listaReceta.push(item);
            dibujarTablaReceta();

            // Limpiar inputs
            $("#cboMedicamento").val(''); $("#txtDosis").val(''); $("#txtCantidad").val('1'); $("#txtIndicaciones").val('');
        }

        function eliminarMedicamento(index) {
            listaReceta.splice(index, 1);
            dibujarTablaReceta();
        }

        function dibujarTablaReceta() {
            if (listaReceta.length === 0) {
                $("#tablaReceta tbody").html('<tr id="filaVacia"><td colspan="5" class="text-center text-muted py-3">No ha agregado medicamentos a la receta.</td></tr>');
                return;
            }
            let html = "";
            for (let i = 0; i < listaReceta.length; i++) {
                html += `<tr>
                            <td class="fw-bold">${listaReceta[i].Nombre.split('-')[0]}</td>
                            <td>${listaReceta[i].Dosis}</td>
                            <td class="text-center fw-bold">${listaReceta[i].Cantidad}</td>
                            <td>${listaReceta[i].Indicaciones}</td>
                            <td class="text-center">
                                <button type="button" class="btn btn-sm btn-outline-danger" onclick="eliminarMedicamento(${i})"><i class="fas fa-trash"></i></button>
                            </td>
                         </tr>`;
            }
            $("#tablaReceta tbody").html(html);
        }

        // 3. GUARDADO FINAL TRANSACCIONAL
        function guardarFicha() {
            // Validaciones de UI
            let esValido = true;
            if(!$("#txtMotivo").val().trim()) {
                $("#txtMotivo").addClass("is-invalid"); $("#errMotivo").removeClass("d-none"); esValido = false;
            }
            if(!$("#txtDiagnostico").val().trim()) {
                $("#txtDiagnostico").addClass("is-invalid"); $("#errDiagnostico").removeClass("d-none"); esValido = false;
            }
            if(!esValido) {
                alert("Por favor, complete el Motivo y el Diagnóstico en la pestaña de Evaluación Clínica.");
                new bootstrap.Tab(document.querySelector('#evaluacion-tab')).show();
                return;
            }

            // Construir Objeto Consulta
            var requestConsulta = {
                ConsultaID: $("#hdnConsultaID").val() ? parseInt($("#hdnConsultaID").val()) : 0,
                CitaID: $("#hdnCitaID").val() ? parseInt($("#hdnCitaID").val()) : null,
                PesoKg: parseFloat($("#txtPeso").val()) || null,
                TallaCm: parseFloat($("#txtTalla").val()) || null,
                PresionArterial: $("#txtPresion").val(),
                Temperatura: parseFloat($("#txtTemp").val()) || null,
                MotivoConsulta: $("#txtMotivo").val(),
                ExamenFisico: $("#txtExamenFisico").val(),
                Diagnostico: $("#txtDiagnostico").val(),
                Tratamiento: listaReceta.length > 0 ? "Ver receta médica adjunta." : "Sin tratamiento farmacológico.",
                Indicaciones: $("#txtIndicacionesGenerales").val() || "",
                ProximaRevision: $("#txtProximaRevision").val() || null
            };

            // Empaquetar Consulta + Receta
            var payload = {
                ConsultaData: requestConsulta,
                ListaReceta: listaReceta
            };

            console.log("Enviando Payload:", payload); // Por si ocupamos depurar en F12

            // Enviar a C#
            $.ajax({
                url: '@Url.Action("Guardar", "Consultas")',
                type: "POST",
                data: JSON.stringify(payload),
                contentType: "application/json; charset=utf-8",
                success: function (response) {
                    if (response.success) {
                        alert("¡Expediente guardado y Receta enviada a Farmacia con éxito!");
                        window.location.href = '/Consultas/Index';
                    } else {
                        alert("Error al guardar: " + response.mensaje);
                    }
                },
                error: function(xhr, status, error) {
                    alert("Error crítico de comunicación con el servidor.");
                    console.error(xhr.responseText);
                }
            });
        }
    </script>
}